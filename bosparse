# checking list:
#   - key(para-name) is a valid shell varaible name with exception
#   - entry data type match PFILTER_ENTRY_TYPES
#   - mcg-name matching MCG_TYPES
#   - defaults matching data type
#   - mcg rules
function pfilter_integrity_check() {
	declare -a mcg_types=() mcg_type=() mcg_name=()
	local mt mn
	declare -A mcg_names=()
	declare -A ec_members=() dc_members=()
	# declare -A eg_members=() sg_members=()

	for mt in "${MCG_TYPES[@]}"; do
		mcg_types+=("${mt#*:}") # assumes MCG_TYPES schema="type:value"
	done

	for pk in "${!p_filter[@]}"; do
		local flt_type="" flt_data="" flt_mcg=""

		flt_schema="${p_filter[${pk}]}"
		extract_def_entry "${OLID}" "${pk}" p_filter flt_type flt_data flt_mcg

		# validate mcg names; collecting mcg data for further validating
		if [[ -n ${flt_mcg} ]]; then
			# mcg names, a paramter might belongs to multiple mcgs
			local IFS='|'
			read -ra mcg_name <<<"${flt_mcg}"
			for mn in "${mcg_name[@]}"; do
				mcg_names["${mn}"]=true
				# counting capital members
				case ${mn:0:1} in
				E) ec_members["${pk}"]="${mn}" ;;
				D) dc_members["${pk}"]="${mn}" ;;
				*) ;;
				esac
				# validate mcg type - matching MCG_TYPES
				if ! is_array_member "${mn:0:1}" mcg_types; then
					pros_tag="${mn}"
					pros_tag2="${mcg_types[*]}"
					exit_with_msg 53
				fi
			done
		fi

		# validate keys - should be valid shell variables
		# finished when loading PFILTER

		# validate filter entry data-type
		if ! is_array_member "${flt_type}" PFILTER_ENTRY_TYPES; then
			pros_tag="${flt_type}"
			pros_tag2="${PFILTER_ENTRY_TYPES[*]}"
			exit_with_msg 51
		fi

		# validate mcg
		#   - mcg types satisfy MCG_TYPES
		# mcg name - leading charactor
		if [[ -n ${flt_mcg} ]]; then
			local IFS='|'
			read -ra mcg_type <<<"${flt_mcg}"
			for mt in "${mcg_type[@]}"; do
				if ! is_array_member "${mt:0:1}" mcg_types; then
					# not valid type
					# raise an error
					pros_tag="${mt}-mark"
					pros_tag2="${mcg_types[*]}"
					exit_with_msg 53
				fi
			done
		fi

		# validate defaults
		pros_tag="${flt_schema}"
		pros_tag2="${flt_type}"
		pros_tag3="${flt_data}"

		# for enum entry, data-field stores the enum values, validating needed
		if [[ -n "${flt_data}" || ${flt_type} == 'enum' ]]; then
			case ${flt_type} in
			# string type entry with boolean defaults
			string) [[ ${flt_data} == true || ${flt_data} == false ]] && exit_with_msg 52 ;;
			# bool type entry wity non-bool default
			bool) [[ ${flt_data} == true || ${flt_data} == false ]] || exit_with_msg 52 ;;
			# empty enum list
			enum) [[ -n ${flt_data} ]] || {
				# printf '%q' "[${pk}]"
				pros_tag=$(printf '%s' "[\"${pk}\"]=\"${flt_schema}\"")
				exit_with_msg 48
			} ;;
			*) ;;
			esac
		fi
	done

	# for exclusion/dependence group members:
	#   - e/E: only one E-member
	#   - d/D: only one D-member
	# counting capital members of mcg
	declare -a em_count=() dm_count=()
	local em dm
	for mn in "${!mcg_names[@]}"; do
		# E-member
		for em in "${!ec_members[@]}"; do
			if [[ ${ec_members["${em}"]} == "${mn}" ]]; then
				em_count+=("${em}")
			fi
		done
		if [[ "${#em_count[@]}" -gt 1 ]]; then
			pros_tag="Exclusion"
			pros_tag2="${mn}"
			pros_tag3="${em_count[*]}"
			exit_with_msg 57
		fi

		# D-member
		for dm in "${!dc_members[@]}"; do
			if [[ ${dc_members["${dm}"]} == "${mn}" ]]; then
				dm_count+=("${dm}")
			fi
		done
		if [[ "${#dm_count[@]}" -gt 1 ]]; then
			pros_tag="Dependence"
			pros_tag2="${mn}"
			pros_tag3="${dm_count[*]}"
			exit_with_msg 57
		fi
	done
	return 0
}

# PFILTER name or serialize PFILTER stored in CONFIGS while parsing if supplied; or it
# will be ${CONST["NO_PFILTER"]} as default
# two ways to pass PFILTER in:
#   PFILTER name reference - for an associative array, used in source mode
#   serialized PFILTER - a json string, used for all modes
# a valid PFILTER must include a memeber whose key is "PARA-FILTER" as identifier
function validate_pfilter() {
	local pf_name=$1
	local pf pk new_pk
	local p_filter
	local flt_schema flt_type flt_data flt_mcg

	# pf_name="${CONFIGS[${PSETS["pf"]%%:*}]}"
	if validate_shell_variable_name pf_name true; then
		# may be an associative array name reference
		if pf=$(declare -p "${pf_name}" 2>/dev/null); then
			if [[ ${pf} == "declare -A "* ]]; then
				# an associative array, check id
				if is_array_key "${PFILTER_ID}" "${pf_name}"; then
					# id check passed
					declare -n "p_filter=${pf_name}"
				else
					pros_tag="no identifier key '\${PARA-FILTER}'"
					exit_with_msg 49
				fi
			else
				pros_tag="not an associative array."
				exit_with_msg 49
			fi
		else
			pros_tag="'${pf_name}' should be a PFILTER name reference (source mode) or a string of serialized PFILTER(all modes)"
			exit_with_msg 49
		fi
	else # not valid shell variable, try to deserialize
		local -A p_filter
		deserialize_assoc_array "${pf_name}" p_filter
		# might be serialized associative array
		if ! is_array_key "${PFILTER_ID}" p_filter; then
			pros_tag="no identifier key '${PFILTER_ID}'"
			exit_with_msg 49
		fi
	fi

	# remove PFILTER_ID
	unset "p_filter[${PFILTER_ID}]"

	# load PFILTER with exception substitution on key
	for pk in "${!p_filter[@]}"; do
		new_pk="${pk}"
		if validate_shell_variable_name new_pk true; then
			PFILTER["${new_pk}"]="${p_filter[${pk}]}"
		else # para-nmae invalid
			pros_tag="${pk}"
			exit_with_msg 58
		fi
	done

	# integrity checking:
	pfilter_integrity_check

	msg_bp 3 "    PFILTER validated."
}

