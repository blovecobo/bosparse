# Primitives -------------------------------------------------------------------

# check if the parameter is a array key
function echo2() { echo >&2 "$@"; }

function is_array_key() {
	local key=$1
	local -n arr_ref=${2:-} # array might not available
	local k
	for k in "${!arr_ref[@]}"; do
		[[ ${k} == "${key}" ]] && return 0
	done
	return 1
}

# chck if a string is a array member
function is_array_member() {
	local str=$1
	local -n arr_ref=${2:-} # array might not available

	local mem
	for mem in "${arr_ref[@]}"; do
		[[ ${mem} == "${str}" ]] && return 0
	done
	return 1
}

# feature:
#   show msg by msg_level
#   a nective msg_level number means show msgs in one-line(no CR)
function msg_bp() {
	local msg_level=${1:-0} title=${2:-} content=${3:-}

	# nothing to show
	[[ "${verbose}" == 0 || -z "${verbose}" ]] && return 0
	[[ -n "${title}" ]] || {
		echo
		return 0
	}

	if [[ "${msg_level}" -lt 0 ]]; then
		in_one_line=true
		msg_level=$((0 - msg_level))
	fi

	if [[ "${verbose}" -ge "${msg_level}" ]]; then
		if [[ "${in_one_line:-false}" == true ]]; then
			echo -e "\e[33m${title}\e[0;2m${content}\e[0m" >&2
		else
			[[ -n "${title}" ]] && echo -e "\e[33m${title}\e[0m" >&2
			[[ -n "${content}" ]] && echo -e "\e[2m${content}\e[0m" >&2
		fi
	fi
	return 0
}

# Expand simple ${varname} templates in messages for safe printing.
function template_expand() {
	local template=$1
	# Replace known placeholders safely. Add more as needed.
	template=${template//\$\{pros_tag\}/"${pros_tag}"}
	template=${template//\$\{pros_tag2\}/"${pros_tag2}"}
	template=${template//\$\{pros_tag3\}/"${pros_tag3}"}
	template=${template//\$\{pros_tag4\}/"${pros_tag4}"}
	template=${template//\$\{pros_tag5\}/"${pros_tag5}"}
	printf '%s' "${template}"
}

# exit with a specific exit code and a revelant message
function exit_with_msg() {
	local exit_code=$1
	local additional_msg=${2:-}
	local last_command=${3:-}
	local msg

	# trc
	if [[ ${verbose} -ge 3 ]]; then
		# use developer message
		is_array_key "$((exit_code + 100))" EXIT_MSG && ((exit_code += 100))
	fi

	if [[ "${verbose:-0}" -gt 0 ]]; then
		msg="${EXIT_MSG[${exit_code}]}"

		# expand any template variables (e.g., ${pros_tag}) in message safely
		local _msg_expanded
		_msg_expanded=$(template_expand "${msg}")
		printf '\e[33merror %d:\e[0m %s\n' "${exit_code}" "${_msg_expanded}" >&2
		if [[ -n "${additional_msg}" ]]; then
			_msg_expanded=$(template_expand "${additional_msg}")
			printf '\e[2m        %s\e[0m\n' "${_msg_expanded}" >&2
		fi
		if [[ -n "${last_command}" ]]; then
			# Run the additional command in a subshell to avoid unsafe eval in current shell
			bash -c -- "${last_command}" >&2
		fi
	fi
	exit "${exit_code}"
}

# Test if a string contains a leading-id
#   if lid specified, test with it
#   or try all lids
function with_lid() {
	local para=$1 lid=${2:-}
	if [[ -n ${lid} ]]; then
		[[ ${para} == "${lid}" ]] && return 0
		[[ ${para} =~ ^${lid}[^${lid:0:1}].*$ ]] && return 0
		return 1
	else
		# try all lids
		for lid in "${LIDS[@]}"; do
			[[ ${para} == ${lid}* ]] && return 0
		done
		return 1
	fi
}

# calculate the max length amoung MEMBERs of an array
# usage
#   max_array_member_len arrayref max_len_ref "${additional_len}"
function max_array_member_len() {
	local -n arr_ref="$1" length_max="$2"
	local add_len="${3:-0}" # optional

	if [[ ${#arr_ref[@]} == 0 ]]; then
		length_max=0
	else
		length_max=$(($(
			for member in "${arr_ref[@]}"; do
				echo "${member}"
			done | wc -L
		) + add_len))
	fi
}

# calculate the max length amoung KEYs of an array
# usage:
#   max_array_key_len arrayref max_len_ref "${additional_len}"
function max_array_key_len() {
	local -n arr_ref="$1" len_max="$2"
	local add_len="${3:-0}" # optional

	declare -a keys=("${!arr_ref[@]}")

	max_array_member_len keys len_max "${add_len}"
}

# show array in a formatted way with specified separator, default separator is '-'
function show_array() {
	local -n target_arr=$1
	local separator=${2:--}
	local key lmax=0
	declare -a keys_array

	# build keys array
	keys_array=("${!target_arr[@]}")

	max_array_member_len keys_array lmax 2
	for key in "${!target_arr[@]}"; do
		printf "%${lmax}s %s %s \n" "${key}" "${separator}" "${target_arr[${key}]}" >&2
	done
}

function substitued_exception() {
	local -n var_name_with_exceptions=${1:-}

	[[ -n ${var_name_with_exceptions} ]] || return 0

	for orig in "${!EXCEPTIONS[@]}"; do
		var_name_with_exceptions=${var_name_with_exceptions//"${orig}"/"${EXCEPTIONS[${orig}]}"}
	done
}
# bash variable naming convention
# hyphens are permitted if they are not at the very beginning
# replacing hyphens by underscores
# trailing-tag should be removed in advance, or will be interpreted as underscore
function validate_shell_variable_name() {
	local -n var_name_ref="$1"
	local return_on_error=${2:-false}

	# echo "var_name_ref= $var_name_ref"
	[[ ${var_name_ref} =~ ^[a-zA-Z_][a-zA-Z0-9_-]*$ ]] || {
		if [[ ${return_on_error} == true ]]; then
			return 1
		else
			pros_tag="${var_name_ref}"
			exit_with_msg 26
		fi
	}

	# replace exceptions
	substitued_exception var_name_ref
	return 0
}

# Helper functions ------------------------------------------------------------

# reset verbose to "standard"
function reset_verbose() {
	local v
	for v in "quiet" "extra" "debug" "trace"; do
		CONFIGS["${PSETS[${v}]%%:*}"]=false
	done
	CONFIGS["${PSETS["standard"]%%:*}"]=true
	verbose=1
}
# turn output settings to verbose
# trace > debug > extra > standard > quiet
function update_verbose() {
	[[ $# -eq 1 ]] && local super_verbose=${1:-}
	# echo "super verbose in update: ${super_verbose:-}" >&2
	case ${super_verbose:-} in
	trace) CONFIGS["${PSETS["trace"]%%:*}"]=true ;;
	debug) CONFIGS["${PSETS["debug"]%%:*}"]=true ;;
	extra) CONFIGS["${PSETS["extra"]%%:*}"]=true ;;
	quiet) CONFIGS["${PSETS["quiet"]%%:*}"]=true ;;
	*) ;;
	esac

	[[ ${CONFIGS["${PSETS["quiet"]%%:*}"]} == true ]] && {
		__QUIET=true
		verbose=0
	}
	[[ ${CONFIGS["${PSETS["standard"]%%:*}"]} == true ]] && {
		CONFIGS["${PSETS["quiet"]%%:*}"]=false
		__QUIET=false
		__STANDARD=true
		verbose=1
	}
	[[ ${CONFIGS["${PSETS["extra"]%%:*}"]} == true ]] && {
		CONFIGS["${PSETS["quiet"]%%:*}"]=false
		CONFIGS["${PSETS["standard"]%%:*}"]=true
		__QUIET=false
		__STANDARD=true
		__EXTRA=true
		verbose=2
	}
	[[ ${CONFIGS["${PSETS["debug"]%%:*}"]} == true ]] && {
		CONFIGS["${PSETS["quiet"]%%:*}"]=false
		CONFIGS["${PSETS["standard"]%%:*}"]=true
		CONFIGS["${PSETS["extra"]%%:*}"]=true
		__QUIET=false
		__STANDARD=true
		__EXTRA=true
		__DEBUG=true
		verbose=3
	}
	[[ ${CONFIGS["${PSETS["trace"]%%:*}"]} == true ]] && {
		CONFIGS["${PSETS["quiet"]%%:*}"]=false
		CONFIGS["${PSETS["standard"]%%:*}"]=true
		CONFIGS["${PSETS["extra"]%%:*}"]=true
		CONFIGS["${PSETS["debug"]%%:*}"]=true
		__QUIET=false
		__STANDARD=true
		__EXTRA=true
		__DEBUG=true
		__TRACE=true
		verbose=4
	}
	[[ -n ${verbose:-} ]] || {
		verbose=1
		__STANDARD=true
	}
	return 0
}

function is_in_resyms() {
	local para=$1
	local resym
	for resym in "${RESYMS[@]}"; do
		[[ ${para} =~ ^${resym}+$ ]] && return 0
	done
	return 1
}
# return code:
#  0 - arg                          an arg only
#  1 - <lid><plid>liga              liga   | with trailing tag
#  2 - <lid>bopara(=[true|false])?  bool   | built-in arg(true/false) or with trailing tag
#  3 - <lid>bopara<space(s)>arg     bool   | consume an arg
#  4 - <lid>sopara=arg              string | built-in arg
#  5 - <lid>sopara<space(s)>arg     string | consume an arg
#  6 - <other-lid>para              alter  | not need an arg
#  7 - <other-lid>para<space(s)>arg alter  | consume an arg
function check_para_type() {
	local lid=$1 current=$2 next=$3
	local -n para_ref=$4
	local para_name arg

	# echo "${lid} | ${current} | ${next}"
	# echo "lid:  $lid"
	# echo "curr: $current | next: $next"

	para_ref="${current}"

	if with_lid "${current}" "${lid}${lid}"; then
		# '--current' or '~~current' like, liga
		return 1
	elif with_lid "${current}" "${lid}"; then
		# '-current ' like, with lid
		if [[ "${current}" == *${OSEP}* ]]; then
			# '-current=arg' like, depends on arg
			para_name=${current%%"${OSEP}"*} # %% incase arg contains OSEP
			arg=${current#*"${OSEP}"}        # extract arg
			if [[ ${arg} == true ]]; then
				# '-currnt=true' like, a bool
				para_ref="${para_name}${TAG_TRUE}"
				return 2
			elif [[ ${arg} == false ]]; then
				# '-current=false' like, a bool
				para_ref="${para_name}${TAG_FALSE}"
				return 2
			else
				# '-current="right now"' like, a string
				return 4
			fi
		elif with_lid "${next}" || [[ -z "${next}" ]]; then
			# '-current -next' like, or no next(reach end), a bool
			return 2
		else
			# '-current next' like, next is an arg
			para_name=${current#"${lid}"}
			if [[ ${next} == true ]]; then
				# '-current true' like, a bool(next is a boolean value)
				para_ref="${para_name}${TAG_TRUE}"
				return 3
			elif [[ ${next} == false ]]; then
				# '-current false' like, a bool(next is a boolean value)
				para_ref="${para_name}${TAG_FALSE}"
				return 3
			else
				# '-current "year of 1984"' like, a string(next is not a boolean value)
				para_ref="${current}=${next}"
				return 5
			fi
		fi
	elif with_lid "${current}"; then
		# '<alter-lid>current ' like, match other lids
		if with_lid "${next}" || [[ -z "${next}" ]]; then
			# '<alter-lid>current <lid>next' like
			# or '<alter-lid>current --' like, not consume an arg
			return 6
		else
			# '<lid>current next' like, will consume an arg
			# when 'current == *${OSEP}*' like, it will be an input error
			# leave it to alter-lid parsing to handle
			return 7
		fi
	else # without any lid, an arg; leave it to further parsing
		return 0
	fi
}

# check possible trailing tag for a para-name
function parse_bool_tag() {
	local para=$1
	local tag=${para: -1}

	case "${tag}" in
	"${TAG_TRUE}") echo true ;;
	"${TAG_FALSE}") echo false ;;
	*) echo "${TAG_DEFAULT}" ;;
	esac
}

# apply Priors/PSets settings to CONFIGS
function apply_setup() {
	local title=$1
	local -n setup_ref=$2

	local ps
	# merge PSets
	for ps in "${!BP_STRINGS[@]}"; do
		BP_OPARAS["${ps}"]="${BP_STRINGS[${ps}]}"
	done
	for ps in "${!BP_BOOLS[@]}"; do
		BP_OPARAS["${ps}"]="${BP_BOOLS[${ps}]}"
	done

	msg_bp 4 "  ${title} before applying settings:" >&2
	# apply settings to CONFIGS
	field_len=$(
		for ps in "${!BP_OPARAS[@]}"; do
			echo "${ps}"
		done | wc -L
	)
	for ps in "${!BP_OPARAS[@]}"; do
		msg_bp 4 "    $(printf "%${field_len}s | %s\n" "${ps}" "${BP_OPARAS[${ps}]}")" >&2
		CONFIGS["${setup_ref["${ps}"]%%:*}"]="${BP_OPARAS["${ps}"]}"
	done
}

# Reset all intermediate results arrays, for re-parsing if needed
function reset_intermediate_arrays() {
	local reset_zone_arra=${1:-true}
	for arr_name in BP_OPARAS BP_BOOLS BP_STRINGS BP_PPARAS strings bools ligas; do
		declare -n arr_ref="${arr_name}"
		arr_ref=()
	done
	[[ "${reset_zone_arra}" == true ]] || return 0
	op_zone=()
	pp_zone=()
	return 0
}

