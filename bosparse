# usage:
#   pf_str=$(serialize_assoc_array PFILTER)
function serialize_assoc_array() {
	local -n arr=$1

	command -v jq >/dev/null 2>&1 || {
		echo "jq required for serialization" >&2
		return 1
	}

	local json first=1 k_esc v_esc

	json="{"
	for k in "${!arr[@]}"; do
		if [[ ${first} -eq 0 ]]; then json+=","; fi
		k_esc=$(jq -n --arg s "${k}" '$s')
		v_esc=$(jq -n --arg s "${arr[${k}]}" '$s')
		json+="${k_esc}: ${v_esc}"
		first=0
	done
	json+="}"

	echo "${json}"
}

# usage:
#   deserialize_assoc_array "$pf_str" PFILTER
deserialize_assoc_array() {
	local json="$1"
	local -n arr_name="$2"

	# declare -gA "${arr_name}"
	# local -n arr="${arr_name}"

	command -v jq >/dev/null 2>&1 || {
		echo "jq required for deserialization" >&2
		return 1
	}

	local keys_values key="" value="" is_key=1

	keys_values=$(echo "${json}" | jq -r 'to_entries[] | "\(.key)\n\(.value)"')
	while IFS= read -r line; do
		if [[ ${is_key} -eq 1 ]]; then
			key="${line}"
			is_key=0
		else
			value="${line}"
			# arr["$key"]="${value}"
			arr_name["${key}"]="${value}"
			is_key=1
		fi
	done <<<"${keys_values}"
}

# extract type and data field from definition entry
# for PLID/PRLID, remove conf_name field before extraction
function extract_def_entry() { # !! needs to reform
	local lid=$1 p_key=$2
	local -n p_def=$3 p_type=$4 p_data=$5

	if [[ $# == 6 ]]; then
		local -n p_mcg=${6:-}
	else
		local p_mcg=""
	fi

	local p_schema="${p_def[${p_key}]}"

	# issue: empty schema cannot be checked
	# [[ -n "${p_schema}" ]] || {
	# 	pros_tag="${p_key}"
	# 	pros_tag2="schema is empty."
	# 	exit_with_msg 50
	# }

	# for PLID/PRLID, remove conf_name field
	[[ ${lid} == "${OLID}" ]] || p_schema=${p_schema#*:}

	# use read instead of awk to speed up
