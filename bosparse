# validate:
#   if exactly match a filter-defined name
#   if not, if prefix-matching
# output:
#	zero matched:     ""
#   one matched:      expactly/prefixly matched name
#   multiple matched: matching names
function prefix_matching_filter() {
	local candidate=$1
	local -n matching_arr=$2
	local pk
	local -a matching_list=()

	# bp_msg 4 "      prefix-matching: ${candidate}"

	# try exactly match
	if is_array_key "${candidate}" matching_arr; then
		echo "${candidate}"
		return 0
	fi

	# try prefix-match
	for pk in "${!matching_arr[@]}"; do
		[[ ${pk} =~ ^${candidate} ]] && matching_list+=("${pk}")
	done

	if [[ "${#matching_list[@]}" -eq 1 ]]; then
		# one matched
		echo "${matching_list[0]}"
		return 0
	elif [[ ${#matching_list[@]} -eq 0 ]]; then
		# none  matched
		return 1
	else
		# multiple matched
		echo "${matching_list[*]}"
		return 2
	fi
}

# validate a single para name by prefix-matching
# prefix-matching is an upgrade function of alias
# try to match the para name with matching_filter(PRIORS/PSETS/PFILTER) key.
# when successfully matched, then exact para name will be returned
function validate_para_name() {
	local -n para_ref=$1 matching_filter=$2
	local mandatory=${3:-true}

	local matched_names rtn=0

	# bp_msg 4 "      validate para: ${para_ref} | mandatory: ${mandatory}"

	matched_names=$(prefix_matching_filter "${para_ref}" matching_filter) || rtn=$?
	# prefix_matching_filter "${para_ref}" matching_filter

	if [[ ${rtn} -eq 0 ]]; then
		# matched(exact or prefix-), return the exact name
		para_ref="${matched_names}"
		return 0
	elif [[ ${mandatory} == true ]]; then
		# not matched but mandataory required
		case ${rtn} in
		1) # not matched
			if [[ ${lid} == "${OLID}" ]]; then
				pros_tag="'${para_ref}'"
				exit_with_msg 45
			else
				pros_tag="${ptitle}"
				pros_tag2="${lid}${para_ref}"
				exit_with_msg 43
			fi
			;;
		2) # multiple matched
			pros_tag="${ptitle}"
			pros_tag2="${para_ref}"
			pros_tag3="${matched_names}"
			exit_with_msg 25
			;;
		*) ;;
		esac
	fi
	return 0
}

# validating a single para with given type and data
# used for Priors/PSets/UParas
function validate_para_arg() {
	local para=$1 e_para=$2 pf_type=$3 pf_data=$4

	# echo para: $para
	local val=${v_oparas[${e_para}]}

	pros_tag="${ptitle}"

	[[ ${verbose} -ge 4 ]] && printf "    \e[2m%-8s - %-10s | %-6s | %s\n\e[0m" "${para}" "${e_para}" "string" "${val}" >&2
	case ${pf_type} in
	enum) # this branch must in front of "bool" branch in case EMAB
		# [[ ${verbose} -ge 4 ]] && printf "    \e[33m%-8s - %-10s\e[0;2m %-6s | %s\n\e[0m" "${para}" "${e_para}:" "enum" "'${pf_data}'" >&2
		# split enum string safely into array, handling escaped pipes
		local pf_data_escaped
		pf_data_escaped=$(echo "${pf_data}" | sed 's/\\|/__PIPE__/g')
		local IFS='|'
		read -ra enum_list <<<"${pf_data_escaped}"
		# Restore escaped pipes
		for i in "${!enum_list[@]}"; do
			enum_list[$i]=$(echo "${enum_list[$i]}" | sed 's/__PIPE__/|/g')
		done
		# local IFS=';'
		# read -ra enum_list <<<"${pf_datad}"
		if [[ ${val} == true || ${val} == false ]]; then
			# an enum parameter want to use last value (-enum-para) may be missmatched as booleans(enum mismatched as booleans EMAB)
			# remove the paramter from v_bools and v_oparas
			# add re-assign with the last item of enum list
			unset "v_bools[${e_para}]"
			v_oparas[${e_para}]="${enum_list[-1]}"
			v_strings[${e_para}]="${enum_list[-1]}"
			return 0
		fi
		# if not in enum list, parsing failed
		if ! is_array_member "${val}" enum_list; then
			pros_tag2="${para}=${val}"
			pros_tag3="'${pf_data//|/\/}'"
			exit_with_msg 40
		fi
		;;
	bool)
		# [[ ${verbose} -ge 4 ]] && printf "    \e[33m%-8s - %-10s\e[0;2m %-6s | %s\n\e[0m" "${para}" "${e_para}:" "bool" "${val}" >&2
		if [[ ${val} != true && ${val} != false ]]; then
			pros_tag2="${para}=${val}"
			pros_tag3="'true/false'"
			exit_with_msg 40
		fi
		;;
	string)
		if [[ ${val} == true || ${val} == false ]]; then
			pros_tag2="${para}=${val}"
			pros_tag3="a string but got a bool"
			exit_with_msg 40
		fi
		;;
	resym)
		# [[ ${verbose} -ge 4 ]] && printf "    \e[33m%8s - %-10s\e[0;2m %-6s | %s\n\e[0m" "${para}" "${e_para}:" "resym" "${val}" >&2
		is_in_resyms "${val//[0-9/]}" || {
			pros_tag2="${para}=${val}"
			pros_tag3="a RESYM or a RESYM-repetition but got '${val}'"
			exit_with_msg 40
		}
		# validate length of resym if specified in pf_data, e.g. "resym:3" means a resym with length of 3
		resym_len=${pf_data//[^[:digit:]]/}
		[[ -n ${resym_len} ]] || resym_len=1
		if [[ ${#val} -ne ${resym_len} ]]; then
			pros_tag2="${para}=${val}"
			pros_tag3="mismatch length, value length should be '${resym_len}' instead of '${#val}'"
			exit_with_msg 41
		fi
		# check exclude resyms
		exclude_resym="${pf_data//[0-9]/}"
		if [[ ${val} =~ [${exclude_resym}] ]]; then
			pros_tag2="${para}=${val}"
			pros_tag3="contains resym(s) not permitted '${exclude_resym}'"
			exit_with_msg 41
		fi
		;;
	*) # will not happen
		# pros_tag="${para}=${val}"
		# pros_tag2="${pf_type}"
		# pros_tag3="${ptitle} definition"
		# exit_with_msg 41
		;;
	esac
	return 0
}

# check mutual-exclusion groups to ensure paras in the same meg do not have same values;
# fields may omit if empty from end
# applied for both Priors/PSets/User OParas
function validate_para_meg() {
	bp_msg 3 "  - check mutual-exclusion groups"

	local -n filter_ref=$1 vpe_paras=$2
	# echo "current filter:"
	# show_array filter_ref
	# echo "current paras for checking:"
	# show_array vpe_paras

	# get all meg names
	declare -A meg_groups=()
	local meg_field member_meg member_megs dummy

	for member in "${!filter_ref[@]}"; do
		extract_def_entry "${lid}" "${member}" filter_ref dummy dummy meg_field
		# echo "meg: ${meg_field:-}"
		if [[ -n ${meg_field:-} ]]; then
			# if a para belongs to multiple meg, separate meg names with vertical line '|', e.g.
			# "meg1|meg2", the para will be checked in all the meg it belongs to.
			for meg in ${meg_field//|/ }; do
				meg_groups["${meg}"]=true
			done
		fi
	done
	local meg_names=("${!meg_groups[@]}")

	for meg in "${meg_names[@]}"; do
		bp_msg 4 "    checking meg:" "${meg}"
		declare -a meg_members=()
		declare -a meg_values=()

		# find members in the same meg
		for member in "${!filter_ref[@]}"; do
			member_meg=${filter_ref[${member}]##*:}
			# safely split meg names into array
			local IFS='|'
			read -ra member_megs <<<"${member_meg}" # may belong to multiple megs
			if is_array_member "${meg}" member_megs; then
				meg_members+=("${member}")
			fi
		done

		local default_value
		# collect values of members in this meg
		for member in "${meg_members[@]}"; do
			if is_array_key "${member}" vpe_paras; then
				# supplied
				bp_msg 4 "      member" "'${member}'"
				meg_values+=("${vpe_paras[${member}]}")
			elif [[ ${lid} == "${OLID}" ]]; then
				# not supplied, use default value in PFILTER for checking;
				# for UParas, if a member is not supplied, use default value in PFILTER for
				# checking; if no default value, parsing failed
				bp_msg 4 "      member" "'${member}' not supplied, use PFILTER default for checking"
				extract_def_entry "${lid}" "${member}" filter_ref dummy default_value meg_field
				if [[ -n ${default_value:-} ]]; then
					meg_values+=("${default_value}")
				else
					pros_tag="${member}"
					exit_with_msg 46
				fi
			else
				# for Priors/PSets, if a member is not supplied, use values in CONFIGS for checking
				bp_msg 4 "      member" "'${member}' not supplied, use CONFIGS value for checking"
				if [[ ${lid} == "${PLID}" ]]; then
					meg_values+=("${CONFIGS[${PSETS[${member}]%%:*}]}")
				elif [[ ${lid} == "${PRLID}" ]]; then
					meg_values+=("${CONFIGS[${PRIORS[${member}]%%:*}]}")
				fi
			fi
		done

		# raise an error if duplicated
		if [[ ${#meg_values[@]} -ne $(printf '%s\n' "${meg_values[@]}" | sort -u | wc -l) ]]; then
			pros_tag="${meg}"
			pros_tag2="${meg_members[*]}"
			exit_with_msg 37
		fi
		bp_msg 4 "      - PASSED"
	done
}

# validate BP_OPARAS(Priors/PSets/User-OParas) with their definitions(PRIORS/PSETS/PFILTER)
function validate_paras_by_filter() {
	local lid=$1 mandatory=${2:-true}
	# local -n def=$2
	declare -A v_oparas=() v_strings=() v_bools=()

	local ptitle exact_para
	local para pf_type pf_data

	case ${lid} in
	"${OLID}") # for user parameters
		declare -n def=PFILTER
		ptitle="Parameter"
		;;
	"${PLID}") # for PSets
		declare -n def=PSETS
		ptitle="PSet"
		;;
	"${PRLID}") # for Priors
		declare -n def=PRIORS
		ptitle="Prior"
		;;
	*) ;;
	esac

	bp_msg 3 "  - validate name and arg:"
	[[ ${verbose} -ge 4 ]] && printf "    \e[4;33m%-8s - %-10s | %-6s | %s\n\e[0m" "supplied" "matched" "type" "data" >&2
	for para in "${!BP_OPARAS[@]}"; do
		# bp_msg 4 "    $para:"
		# validate name
		exact_para="${para}"
		validate_para_name exact_para def "${mandatory}"
		# bp_msg -4 "      new name:" "${exact_para}"
		v_oparas["${exact_para}"]="${BP_OPARAS["${para}"]}"
		is_array_key "${para}" BP_STRINGS && v_strings["${exact_para}"]="${BP_STRINGS["${para}"]}"
		is_array_key "${para}" BP_BOOLS && v_bools["${exact_para}"]="${BP_BOOLS["${para}"]}"

		# check arg
		#   - if defined in def, do arg checking;
		#   - if not defined, let it be (for non-mandatory case)
		if is_array_key "${exact_para}" def; then
			extract_def_entry "${lid}" "${exact_para}" def pf_type pf_data
			validate_para_arg "${para}" "${exact_para}" "${pf_type}" "${pf_data}"
		else # not defined in def, let it be
			:
		fi
	done

	# show_array v_oparas "opara"
	# show_array v_bools "bool"
	# show_array v_strings "string"

	# check meg conflict
	validate_para_meg def v_oparas

	# load validated paras into result arrays
	reset_intermediate_arrays false
	for para in "${!v_oparas[@]}"; do
		BP_OPARAS["${para}"]="${v_oparas[${para}]}"
	done
	for para in "${!v_strings[@]}"; do
		BP_STRINGS["${para}"]="${v_strings[${para}]}"
	done
	for para in "${!v_bools[@]}"; do
		BP_BOOLS["${para}"]="${v_bools[${para}]}"
	done
}

# assign user parameters with defaults if not supplied
#   - for string/bool type, use data field
#   - for enum type, use first enum as default value
function assign_user_para_defaults() {
	local para=$1 pf_type=$2 pf_data=$3

	# bp_msg 3 "    ${para} | ${pf_type} | ${pf_data:--}"
	# [[ ${verbose} -ge 3 ]] && printf "    \e[33m%-12s\e[0;2m - type: %-6s | value: %s\n\e[0m" "${para}:" "${pf_type}" "${BP_OPARAS[${para}]:--}" >&2
	[[ ${verbose} -ge 4 ]] && printf "    \e[2;33m%-12s - %6s | %s\n\e[0m" "${para}" "${pf_type}" "${pf_data:--}" >&2
	case "${pf_type}" in
	bool | string)
		if [[ -n ${pf_data} ]]; then
			# default value specified in PFILTER
			BP_OPARAS["${para}"]="${pf_data}"
			if [[ ${pf_type} == "bool" ]]; then
				BP_BOOLS["${para}"]="${pf_data}"
			else
				BP_STRINGS["${para}"]="${pf_data}"
			fi
		else # not supplied && no default value, parsing failed
			pros_tag="${para}"
			exit_with_msg 46
		fi
		# [[ ${verbose} -ge 4 ]] && printf "    \e[33m%-12s\e[0;2m - type: %-6s | value: %s\n\e[0m" "${para}:" "${pf_type}" "${BP_OPARAS[${para}]:-undefined}" >&2
		[[ ${verbose} -ge 3 ]] && printf "    \e[2m%-12s - %6s | %s\n\e[0m" "${para}" "${pf_type}" "${BP_OPARAS[${para}]:--}" >&2
		;;
	enum)
		# set with first enum as default value
		default_enum=${pf_data%%'|'*}
		BP_OPARAS["${para}"]="${default_enum}"
		# enum type is treated as string in BP_OPARAS(true|false should be set as Booleans)
		BP_STRINGS["${para}"]="${default_enum}"
		# [[ ${verbose} -ge 4 ]] && printf "    \e[33m%-12s\e[0;2m - type: %-6s | value: %s\n\e[0m" "${para}:" "enum" "${BP_OPARAS[${para}]:-undefined}" >&2
		[[ ${verbose} -ge 3 ]] && printf "    \e[2m%-12s - %6s | %s\n\e[0m" "${para}" "${pf_type}" "${BP_OPARAS[${para}]:--}" >&2
		;;
	*) # this will not happen since integrity checking already done in validate_pfilter
		# pros_tag="${para}"
		# pros_tag2="${pf_type}"
		# exit_with_msg 52
		;;
	esac
	return 0
}

# validate user option parameters by PFILTER
#   validate PFILTER
#   validate para name(include prefixes)
#   validate para values
#   assign defaults for not supplied paras
# key paras:
#   mandatory(~amf): all parameters must be defined in PFILTER
#	PFILTER_ID: identify the PFILTER
function validate_user_paras() {
	bp_msg 2 "Validate user parameters"

	local para pf_type pf_data
	local mandatory no_pfilter=true

	mandatory="${CONFIGS[${PSETS["amf"]%%:*}]}"
	[[ "${CONFIGS[${PSETS["pf"]%%:*}]}" == "${NO_PFILTER}" ]] || no_pfilter=false

	bp_msg 4 "  PFILTER-ID: ${PFILTER_ID} | AMF: ${mandatory}"

	if [[ "${no_pfilter}" == true ]]; then
		[[ ${mandatory} == true ]] && exit_with_msg 44
		bp_msg 3 "  No PFILTER supplied, no validation for supplied parameters."
		return 0
	fi

	declare -A PFILTER
	bp_msg 3 "  validate PFILTER"
	validate_pfilter
	# bp_msg 4 "    PFILTER:"
	# [[ ${verbose} -ge 4 ]] && show_array PFILTER

	bp_msg 3 "  validate paras with PFILTER"
	validate_paras_by_filter "${OLID}" "${mandatory}"

	bp_msg 3 "  - assign default values if not supplied"
	[[ ${verbose} -ge 4 ]] && printf "    \e[4;33m%-12s - %6s | %s\n\e[0m" "para" "type" "data" >&2
	for para in "${!PFILTER[@]}"; do
		# when supplied, no assigning needed
		is_array_key "${para}" BP_OPARAS && continue
		extract_def_entry "${OLID}" "${para}" PFILTER pf_type pf_data
		assign_user_para_defaults "${para}" "${pf_type}" "${pf_data}"
	done
}

function create_variables() {
	local var
	bp_msg 2 "    Option parameters:"

	# bools
	for var in "${!BP_BOOLS[@]}"; do
		declare -g "${var}"="${BP_BOOLS["${var}"]}"
		bp_msg 2 "      ${var}"="${BP_BOOLS["${var}"]}"
	done

	# strings
	for var in "${!BP_STRINGS[@]}"; do
		declare -g "${var}"="${BP_STRINGS[${var}]}"
		bp_msg 2 "      ${var}"="${BP_STRINGS[${var}]}"
	done
}

# output parsing result as arrays with name references specified by user, e.g. if user specified
# "~oan=opara_array" for OAN from CML, then an array named "opara_array" will be created and
# assigned with all OParas, then user can use "${opara_array[@]}" to get all OParas in their
# script; if not specified, no array will be created for that type of paras.
#
# these arrays are for source mode, and will not be output in eval/capture mode since eval/capture
# mode will output variables in other formats; for example, in eval mode, variables will be output as
# variable assignment statements, and in capture mode, variables will be output as JSON string.
function output_para_arrays() {
	local opara_an spara_an bpara_an ppara_an i

	bp_msg 2 "  Output parameter arrays with name references specified in CONFIGS for PSets"

	# option parameters
	opara_an=${CONFIGS["${PSETS["oan"]%%:*}"]}
	max_array_key_len BP_OPARAS key_max_len 6
	if [[ ${opara_an} != "${CONSTS["OAN"]}" ]]; then
		bp_msg 2 "  - Option parameters in '${opara_an}()'"
		declare -gA "${opara_an}=()"
		declare -n arr_ref="${opara_an}"
		for i in "${!BP_OPARAS[@]}"; do
			arr_ref["${i}"]="${BP_OPARAS[${i}]}"
			# bp_msg 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${BP_OPARAS[${i}]}")"
			bp_msg 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${arr_ref[${i}]}")"
		done
	fi

	# bool parameters
	bpara_an=${CONFIGS["${PSETS["ban"]%%:*}"]}
	max_array_key_len BP_Bools key_max_len 6
	if [[ ${bpara_an} != "${CONSTS["BAN"]}" ]]; then
		bp_msg 2 "  - Boolean parameters in '${bpara_an}()'"
		declare -gA "${bpara_an}=()"
		declare -n arr_ref="${bpara_an}"
		for i in "${!BP_BOOLS[@]}"; do
			arr_ref["${i}"]="${BP_BOOLS[${i}]}"
			# bp_msg 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${BP_BOOLS[${i}]}")"
			bp_msg 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${arr_ref[${i}]}")"
		done
	fi

	# string parameters
	spara_an=${CONFIGS["${PSETS["san"]%%:*}"]}
	max_array_key_len BP_Strings key_max_len 6
	if [[ ${spara_an} != "${CONSTS["SAN"]}" ]]; then
		bp_msg 2 "  - String parameters in '${spara_an}()'"
		declare -gA "${spara_an}=()"
		declare -n arr_ref="${spara_an}"
		for i in "${!BP_STRINGS[@]}"; do
			arr_ref["${i}"]="${BP_STRINGS[${i}]}"
			# bp_msg 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${BP_STRINGS[${i}]}")"
			bp_msg 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${arr_ref[${i}]}")"
		done
	fi

	# position parameters
	# PAN is a special case since it is used for identifying the array name for PParas, and it
	# is not necessary to create an array for PParas if user do not specify a name for it; so
	# only when PAN is specified with a different name, the array for PParas will be created.
	ppara_an=${CONFIGS["${PSETS["pan"]%%:*}"]}
	if [[ ${ppara_an} != "${CONSTS["PAN"]}" ]]; then
		bp_msg 2 "  - Positional parameters in '${ppara_an}()'"
		declare -gA "${ppara_an}=()"
		declare -n arr_ref="${ppara_an}"
		if [[ ${#BP_PPARAS[@]} -ne 0 ]]; then
			for i in "${!BP_PPARAS[@]}"; do
				arr_ref["${i}"]="${BP_PPARAS[${i}]}"
				bp_msg 2 "      ${arr_ref[${i}]}"
			done
		fi
	fi
}

# output parsing result as variable assignment statements, for eval mode
function output_eval() {
	# output vars
	local index
	for index in "${!BP_OPARAS[@]}"; do
		echo "${index}=$(printf %q "${BP_OPARAS[${index}]}")"
	done
	# output optional parameters as vars
	# variable name prefix
	ppvn_prefix="${CONFIGS[${PSETS["pan"]%%:*}]}"
	for index in "${!BP_PPARAS[@]}"; do
		echo "${ppvn_prefix,,}_${index}=$(printf %q "${BP_PPARAS[${index}]}")"
	done
}

# output parsing result as JSON, for capture mode
function output_json() {
	# output $BP_OPARAS in JSON using a single jq -n call
	command -v jq >/dev/null 2>&1 || exit_with_msg 47

	local para val idx=0
	local -a jq_args=()
	local expr='{}'

	# helper: valid number check (no leading zeros except '0')
	is_number() {
		[[ $1 =~ ^-?(0|[1-9][0-9]*)(\.[0-9]+)?$ ]]
	}

	for para in "${!BP_OPARAS[@]}"; do
		val="${BP_OPARAS[${para}]}"
		idx=$((idx + 1))
		jq_args+=(--arg "k${idx}" "${para}")
		if [[ "${val}" == "true" || "${val}" == "false" ]]; then
			# boolean literal
			jq_args+=(--argjson "v${idx}" "${val}")
		elif is_number "${val}"; then
			# numeric literal (integers or decimals without leading zeros)
			jq_args+=(--argjson "v${idx}" "${val}")
		else
			# force string
			jq_args+=(--arg "v${idx}" "${val}")
		fi
		expr+=" + {(\$k${idx}): \$v${idx}}"
	done

	# Emit positional parameters as a JSON array under the key 'PParas'
	if [[ ${#BP_PPARAS[@]} -gt 0 ]]; then
		local pparas_json
		pparas_json=$(printf '%s\n' "${BP_PPARAS[@]}" | jq -R -s -c 'split("\n")[:-1]')
		idx=$((idx + 1))
		jq_args+=(--arg "k${idx}" "${CONFIGS[${PSETS["pan"]%%:*}],,}")
		# jq_args+=(--arg "k${idx}" "PParas")
		jq_args+=(--argjson "v${idx}" "${pparas_json}")
		expr+=" + {(\$k${idx}): \$v${idx}}"
	fi

	jq -n "${jq_args[@]}" "${expr}"
}

function direct_pset_commands() {
	# direct commands for some special PSets, which will not be output as user parameters but
	# executed directly in bosparse, e.g. show version or print a message

	# show bosparse tag
	if [[ "${CONFIGS[${PSETS["tag"]%%:*}]}" == true ]]; then
		# echo -e "${CONSTS["PBP"]} with ${CONSTS["EXTRA-FUN"]}"
		echo -e "${CONSTS["PBP"]} with love"
		exit 0
	elif [[ "${CONFIGS[${PSETS["version"]%%:*}]}" == true ]]; then
		# show version
		echo "${CONSTS["BOSPARSE_VERSION"]}"
		exit 0
	elif [[ "${CONFIGS[${PSETS["resyms"]%%:*}]}" == true ]]; then
		# show resym
		echo "Available resyms: ${RESYMS[*]}"
		exit 0
	elif [[ "${CONFIGS[${PSETS["config"]%%:*}]}" == true ]]; then
		# show_configs
		show_configs
		exit 0
	fi
}
# main function ---------------------------------------------------------------
function bosparse() {

	# trap bp_on_exit EXIT

	local_script_path="$(realpath "${BASH_SOURCE[0]}")"
	local_script_dir="${local_script_path%\/*}"
	local_script_name="${local_script_path##*\/}"

	declare -A CONFIGS CONSTS PSETS
	declare -A PRIORS LIDS EXCEPTIONS EXIT_MSG
	declare -a RESYMS PFILTER_TYPES
	# declare -A PSET_FILTER=()

	declare -a op_zone=() pp_zone=()
	declare -a strings=() bools=() ligas=()

	definitions \
		CONFIGS \
		CONSTS \
		PSETS \
		PRIORS \
		LIDS \
		RESYMS \
		EXCEPTIONS \
		EXIT_MSG \
		PFILTER_TYPES

	declare -n PRLID='LIDS["prior"]'
	declare -n PLID='LIDS["plid"]'
	declare -n OLID='LIDS["olid"]'
	declare -n RUN_MODE="CONFIGS[${PSETS["run"]%%:*}]"
	declare -n ZSEP="CONFIGS[${PRIORS["zs"]%%:*}]"
	declare -n OSEP="CONFIGS[${PRIORS["os"]%%:*}]"
	declare -n TAG_TRUE="CONFIGS[${PRIORS["tt"]%%:*}]"
	declare -n TAG_FALSE="CONFIGS[${PRIORS["tf"]%%:*}]"
	declare -n TAG_DEFAULT="CONFIGS[${PRIORS[td]%%:*}]"
	declare -n NO_PFILTER='CONSTS["NO_PFILTER"]'
	declare -n PFILTER_ID='CONSTS["PFILTER_ID"]'

	# arrays for parsing result
	#   - BP_OPARAS is the main result array for all types of OParas
	#   - BP_STRINGS/BP_BOOLS are for storing string/bool type OParas separately
	#   - BP PParas entries are all position parameters
	# BP_PParas defined as global array since it is always needed for source mode, while others
	# defined as local arrays to reduce global variable usage and avoid potential conflicts with
	# user variables; for eval/capture mode, these arrays will not be used directly, so it does
	# not matter if they are global or local.
	declare -A "${CONSTS["OAN"]}"
	declare -A "${CONSTS["SAN"]}"
	declare -A "${CONSTS["BAN"]}"
	declare -ga "${CONSTS["PAN"]}"

	declare -n "BP_OPARAS=${CONSTS["OAN"]}"
	declare -n "BP_STRINGS=${CONSTS["SAN"]}"
	declare -n "BP_BOOLS=${CONSTS["BAN"]}"
	declare -n "BP_PPARAS=${CONSTS["PAN"]}"

	# echo ---------------------
	# echo $* >&2

	update_verbose
	bp_msg 3 "Command line: " "$*"
	bp_msg -2 "verbose: " "${verbose}"

	# treat empty "$@"
	[[ $# -eq 0 || $* == '--' || $* == "${ZSEP}" ]] && exit_with_msg 2

	reset_intermediate_arrays

	# disassemble command line parameters
	bp_msg 2 "Extract zones and parameters from command line"
	extract_zones op_zone pp_zone "$@"

	# show_array op_zone "|"
	# show_array pp_zone "|"

	bp_msg 2 "Extract Priors"
	extract_oparas "${PRLID}" strings bools ligas op_zone || true

	bp_msg 2 "Parse Priors"
	parse_oparas "${PRLID}" strings bools ligas

	if [[ ${#BP_OPARAS[@]} -ne 0 ]]; then
		bp_msg 3 "Validate Priors"
		validate_paras_by_filter "${PRLID}" true

		apply_setup PRIORS
		update_verbose
	fi
	reset_intermediate_arrays

	if [[ ${CONFIGS[${PRIORS["config"]%%:*}]} == true ]]; then
		# if config is true, show configs after parsing Priors
		show_configs
		# set config to false after showing configs, to avoid showing configs again after parsing PSets
		CONFIGS["${PRIORS["config"]%%:*}"]=false
	else
		[[ ${verbose} -ge 3 ]] && show_configs
	fi

	# re-extract zones for PSets and user OParas, in case some prior settings changed
	bp_msg 2 "Extract zones and parameters from command line"
	extract_zones op_zone pp_zone "$@"

	bp_msg 4 "op zone:" "${op_zone[*]}"
	bp_msg 4 "pp zone:" "${pp_zone[*]}"

	# Psets
	bp_msg 2 "Extract PSets"
	extract_oparas "${PLID}" strings bools ligas op_zone || true

	bp_msg 2 "Parse PSets"
	parse_oparas "${PLID}" strings bools ligas

	if [[ ${#BP_OPARAS[@]} -ne 0 ]]; then
		bp_msg 3 "Validate PSets"
		validate_paras_by_filter "${PLID}" true

		apply_setup PSETS
		update_verbose

		# direct commands for some special PSets, which will not be output as user parameters but
		# executed directly in bosparse, e.g. show version or print a message
		direct_pset_commands
	fi
	reset_intermediate_arrays false

	if [[ ${CONFIGS[${PSETS["config"]%%:*}]} == true ]]; then
		# if config is true, show configs after parsing Priors
		show_configs
	else
		[[ ${verbose} -ge 3 ]] && show_configs
	fi
	# parsing user parameter parsing
	bp_msg 2 "Extract user-oparas"
	extract_oparas "${OLID}" strings bools ligas op_zone || true

	bp_msg 2 "Parse user-oparas"
	parse_oparas "${OLID}" strings bools ligas || true
	validate_user_paras

	bp_msg 2 "Parse user-pparas"
	parse_pparas "${pp_zone[@]}"

	# prepare parsing result on user requirement
	bp_msg 2 "Output parsing result"

	# the user set ~run/mode (PSet) will be respect; Otherwise autodetect
	if [[ ${RUN_MODE} == "auto" ]]; then # auto is the default value
		# echo "simple assert: ${BASH_SOURCE[0]} | "$0" "
		# echo "full assert:   $(basename "$(realpath "${BASH_SOURCE[0]}")") | $(basename "$0") "
		#
		# full assertion is necessary since in some edge cases, e.g. when bosparse is called in
		# a script which is sourced by another script, simple assert will fail to detect source
		# mode; in this case, full assert can correctly detect source mode by comparing the real
		# path of BASH_SOURCE[0] with $0, since when sourced, BASH_SOURCE[0] is the path of the
		# sourced script, while $0 is the path of the top-level script.

		# autodetect
		if [[ ${local_script_name} != $(basename "$0") ]]; then
			bp_msg 3 "  Sourced, output option parameters as variables."
			RUN_MODE="source"
		else
			if [[ ${CONFIGS[${PSETS["json"]%%:*}]} == true ]]; then
				bp_msg 3 "Not sourced, use 'capture' mode as 'json' specified."
				RUN_MODE="capture"
			else
				bp_msg 3 "Not sourced, use 'eval' mode as default"
				RUN_MODE="eval"
			fi
		fi
	fi

	case ${RUN_MODE} in
	source)
		bp_msg 3 "  Output as variables."
		create_variables
		output_para_arrays
		;;
	eval)
		bp_msg 3 "  Output as eval statements."
		output_eval
		;;
	capture)
		bp_msg 3 "  Output as JcvsSON."
		output_json
		;;
	*) ;;
	esac
	parsing_result="Mission complete"
	bp_msg 3 "${parsing_result}"
}

__BP_READY=true # identifying bosparse used

# echo "source assert: $(basename "$(realpath "${BASH_SOURCE[0]}")") | $(basename "$0") "
if [[ $(basename "$(realpath "${BASH_SOURCE[0]}")") == $(basename "$0") ]]; then
	# not source mode
	bosparse "$@"
fi
