# PFILTER name or serialize PFILTER stored in CONFIGS while parsing if supplied; or it
# will be ${CONST["NO_PFILTER"]} as default
# two ways to pass PFILTER in:
#   PFILTER name reference - for an associative array, used in source mode
#   serialized PFILTER - a string, used for all modes, e.g.:
#         "gender=enum:male|female:;h=alias:help:;movie1=string::gmv;PARA-FILTER=::;"
# a valid PFILTER must include a memeber whose key is "PARA-FILTER" as identifier
function validate_pfilter() {
	local pf_name pf pk new_pk
	local p_filter
	local flt_entry flt_type flt_data

	pf_name="${CONFIGS[${PSETS["pf"]%%:*}]}"
	if validate_shell_variable_name pf_name true; then
		# may be an associative array name reference
		if pf=$(declare -p "${pf_name}" 2>/dev/null); then
			if [[ ${pf} == "declare -A "* ]]; then
				# an associative array, check id
				if is_array_key "${PFILTER_ID}" "${pf_name}"; then
					# id check passed
					declare -n "p_filter=${pf_name}"
				else
					pros_tag="no identifier key '\${PARA-FILTER}'"
					exit_with_msg 49
				fi
			else
				pros_tag="not an associative array."
				exit_with_msg 49
			fi
		else
			pros_tag="argument of '~pf' should be a PFILTER name reference (source mode) or a string of serialized PFILTER(all modes)"
			exit_with_msg 49
		fi
	else # not valid shell variable, try deserialized PFILTER
		local -A p_filter
		deserialize_assoc_array "${pf_name}" p_filter
		# might be serialized associative array
		if ! is_array_key "${PFILTER_ID}" p_filter; then
			pros_tag="no identifier key '${PFILTER_ID}'"
			exit_with_msg 49
		fi
	fi

	# remove PFILTER_ID
	unset "p_filter[${PFILTER_ID}]"

	# load PFILTER with exception substitution on key
	for pk in "${!p_filter[@]}"; do
		new_pk="${pk}"
		substitued_exception new_pk
		PFILTER["${new_pk}"]="${p_filter[${pk}]}"
	done

	# integrity checking:
	#   - key(para-name) is a valid shell varaible name with exception
	#   - fields separated by colon ':'
	#   - types in PFILTER_TYPES
	#   - defaults matching types
	#   - enums not empty
	for pk in "${!p_filter[@]}"; do

		# echo "pk: $pk"
		flt_entry="${p_filter[${pk}]}"
		extract_def_entry "${OLID}" "${pk}" p_filter flt_type flt_data

		# validate filter type
		if ! is_array_member "${flt_type}" PFILTER_TYPES; then
			pros_tag="${flt_type}"
			pros_tag2="${PFILTER_TYPES[*]}"
			exit_with_msg 51
		fi

		# validate defaults
		pros_tag="${flt_entry}"
		pros_tag2="${flt_type}"
		pros_tag3="${flt_data}"
		if [[ -n "${flt_data}" ]]; then
			case ${flt_type} in
			string) [[ ${flt_data} == true || ${flt_data} == false ]] && exit_with_msg 52 ;;
			bool) [[ ${flt_data} == true || ${flt_data} == false ]] || exit_with_msg 52 ;;
			enum) [[ -n ${flt_data} ]] || exit_with_msg 48 ;;
			*) ;;
			esac
		fi
	done
}

