# bosparse - a parameter parser in&for bash script
# author: blovecobo
# version: 0.1.3
# platform: bash 4.4+
# usage:
#   - source mode:
#       source /path-to-bp/bosparse
#       bosparse [option parameters] -- [positional parameters]
#   - eval mode:
#       eval $(bosparse [option -arameters] -- [positional parameters])
#   - capture mode:
#       json=$(bosparse ~j [option parameters] -- [positional parameters])
#

set -euo pipefail

function trc() {
	local start=${1:-0}
	local fn=("${FUNCNAME[@]}")

	ln_levels="${#BASH_LINENO[@]}"
	[[ ${#fn[@]} -gt "${ln_levels}" ]] || ln_levels="${#fn[@]}"

	fld_len=$(printf '%s\n' "${fn[@]}" | wc -L)

	for ((ll = start; ll < ln_levels; ll += 1)); do
		printf "%${fld_len}s - %s\n" "${fn[ll]}" "${BASH_LINENO[ll]}" >&2
	done
}

function on_exit_bp() {
	[[ ${parsing_result} == "Mission complete." ]] || trc 2
}

