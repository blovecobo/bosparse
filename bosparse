# Extract paras by lid
#   extract option parameters from command line by lid, and store them in arrays passed by reference
#   no para-validating
#   can be used to extract prior/pset/user parameters
# Extra:
#   replace space(s) between OParas/Psets and ARGs with OSEP
function extract_oparas() {
	local lid=$1
	local -n strings_ref=$2 bools_ref=$3 ligas_ref=$4 # for passing back PSets
	local -n CML=$5

	# msg_bp 2 "  extract ${lid}option-paras"

	local curr_para next_para extracted_para para_type i arg_consumed=false

	for i in "${!CML[@]}"; do
		if [[ "${arg_consumed}" == true ]]; then
			# para is the ARG of last para, skip
			arg_consumed=false
			continue
		fi

		curr_para="${CML[i]}"
		next_para="${CML[$((i + 1))]:-}" || next_para=""

		# parse paras
		para_type=0
		check_para_type "${lid}" "${curr_para}" "${next_para}" extracted_para || para_type=$?
		msg_bp 4 "  type: ${para_type} | extracted: ${extracted_para}"
		case "${para_type}" in
		1) ligas_ref+=("${extracted_para}") ;;
		2) bools_ref+=("${extracted_para}") ;;
		3)
			bools_ref+=("${extracted_para}")
			arg_consumed=true
			;;
		4) strings_ref+=("${extracted_para}") ;;
		5)
			strings_ref+=("${extracted_para}")
			arg_consumed=true
			;;
		6) ;; # matching other lid with built-in arg, skip
		7)    # matching other lid followd by an arg, skip with a consumption signal
			arg_consumed=true ;;
		*) # a solitary arg found, parsing failed
			pros_tag="${curr_para}"
			exit_with_msg 24
			;;
		esac
	done
	return 0
}

# extract zone data from cml
function extract_zones() {
	local -n op_zone_ref=$1 pp_zone_ref=$2

	msg_bp 2 "Extract zones"

	shift 2
	local EZ_CML="$*" para

	# count ZSEP
	zsep_count=0
	for para in "$@"; do
		[[ ${para} != "${ZSEP}" ]] || ((zsep_count += 1))
	done

	if [[ ${zsep_count} -gt 1 ]]; then
		# duplicate ZSEPs
		exit_with_msg 3
	elif [[ "${EZ_CML}" == *[[:space:]]${ZSEP} ]]; then
		# OP_ZONE only with trailing ZSEP
		op_zone_ref=("$@")
		unset "op_zone_ref[$(($# - 1))]" # remove last para which is ZSEP
		return 0
	elif [[ ${EZ_CML} == ${ZSEP}[[:space:]]* ]]; then
		# PP_ZONE only with leading zone-sep
		pp_zone_ref=("$@")
		unset "pp_zone_ref[0]"            # remove first para which is ZSEP
		pp_zone_ref=("${pp_zone_ref[@]}") # re-index array after unset
		return 0
	elif [[ ${EZ_CML} == *[[:space:]]${ZSEP}[[:space:]]* ]]; then
		# two zones separated by a a ZONE_SEP
		local seen_zsep=false
		for para in "$@"; do
			if [[ ${seen_zsep} == false ]]; then
				if [[ ${para} == "${ZSEP}" ]]; then
					seen_zsep=true
				else
					op_zone_ref+=("${para}")
				fi
			else
				pp_zone_ref+=("${para}")
			fi
		done
	else # no ZONE_SEP, test first para
		if with_lid "${1:-}"; then
			# OP_ZONE only
			op_zone_ref=("$@")
		else
			# PP_ZONE only
			pp_zone_ref=("$@")
		fi
	fi
}

# split liga into bools, parse values, load into result array
# used for ligas for Pirors/PSets/U-OParas
# only shell variable validating applied on para names.
function parse_ligas() {
	local lid=$1
	local -n ligas_ref2=$2

	local liga liga_name b_name b_nlen b_tag

	msg_bp 3 "  parse ${lid}ligas"

	for liga in "${ligas_ref2[@]}"; do
		# filter out non-liga paras
		with_lid "${liga}" "${lid}" || continue

		liga=${liga#"${lid}"}                    # remove lid
		b_tag=$(parse_bool_tag "${liga}")        # parse tag
		liga=${liga%["${TAG_TRUE}${TAG_FALSE}"]} # remove tag
		b_nlen=${liga%%[^[:digit:]]*}            # extract name length
		[[ -n "${b_nlen}" ]] || b_nlen=1         # default name length 1
		liga_name=${liga#"${b_nlen}"}            # remove length-integer

		msg_bp 4 "    liga:" "${liga} ${b_tag}"

		for ((start = 0; start < ${#liga_name}; start += b_nlen)); do
			b_name="${liga_name:${start}:${b_nlen}}"
			if ! validate_shell_variable_name b_name true; then
				pros_tag="${b_name}"
				pros_tag2="${lid}${liga}"
				exit_with_msg 36
			fi
			BP_BOOLS["${b_name}"]="${b_tag}"
			BP_OPARAS["${b_name}"]="${b_tag}"
		done
	done
}

# parse boolean parameter with trailing-tag; load into result array
# check if a valid shell variable
function parse_bools() {
	local lid=$1
	local -n bs_ref=$2
	local bl b_name b_tag
	msg_bp 3 "  parse ${lid}bools"

	for bl in "${bs_ref[@]}"; do
		b_name=${bl#"${lid}"}                        # remove lid
		b_tag=$(parse_bool_tag "${b_name}")          # parse tag
		b_name=${b_name%["${TAG_TRUE}${TAG_FALSE}"]} # remove tag

		msg_bp -4 "    bool: " "${bl} | ${b_tag}"
		validate_shell_variable_name b_name

		BP_BOOLS["${b_name}"]="${b_tag}"
		BP_OPARAS["${b_name}"]="${b_tag}"
	done
}

# parse string parameter and load result into array
# validate if the para name is a valid shell variable(with exception subsititution)
function parse_strings() {
	local lid=$1
	local -n str_ref=$2
	local str s_name val

	msg_bp 3 "  parse ${lid}strings"

	for str in "${str_ref[@]}"; do
		s_name=${str#"${lid}"}           # remove lid
		s_name=${s_name%%"${OSEP}"*}     # remove OSEP and value
		val="${str#*"${s_name}${OSEP}"}" # extract value(in case value contains OSEP)

		msg_bp 4 "    string: " "${s_name} | ${val:--}"
		# validate para s_name
		validate_shell_variable_name s_name

		BP_STRINGS["${s_name}"]="${val}"
		BP_OPARAS["${s_name}"]="${val}"
	done
}

# parse OParas with all types of paras, and load results into arrays
function parse_oparas() {
	local lid=$1
	local -n strings_ref=$2 bools_ref=$3 ligas_ref=$4

	parse_ligas "${lid}${lid}" ligas_ref
	parse_bools "${lid}" bools_ref
	parse_strings "${lid}" strings_ref
}

# parse PParas, which are all paras in PP_ZONE, and load results into array
function parse_pparas() {
	BP_PPARAS=("$@")
	msg_bp 3 "  PParas parsed: " "$*"
}

# validate:
#   if exactly match a filter-defined name
#   if not, if prefix-matching
# output:
#	zero matched:     ""
#   one matched:      expactly/prefixly matched name
#   multiple matched: matching names
function prefix_matching_filter() {
	local candidate=$1
	local -n matching_arr=$2
	local pk

	declare -a matching_list=()

	# msg_bp 4 "      prefix-matching: ${candidate}"

	# try exactly match
	if is_array_key "${candidate}" matching_arr; then
		echo "${candidate}"
		return 0
	fi

	# try prefix-match
	for pk in "${!matching_arr[@]}"; do
		[[ ${pk} =~ ^${candidate} ]] && matching_list+=("${pk}")
	done

	if [[ "${#matching_list[@]}" -eq 1 ]]; then
		# one matched
		echo "${matching_list[0]}"
		return 0
	elif [[ ${#matching_list[@]} -eq 0 ]]; then
		# none  matched
		return 1
	else
		# multiple matched
		echo "${matching_list[*]}"
		return 2
	fi
}

# validate a single para name by prefix-matching
# prefix-matching is an upgrade function of alias
# try to match the para name with matching_filter(PRIORS/PSETS/PFILTER) key.
# when successfully matched, then exact para name will be returned
function validate_para_name() {
	local -n para_ref=$1 matching_filter=$2
	local mandatory=${3:-true}

	local matched_names rtn=0

	# msg_bp 4 "      validate para: ${para_ref} | mandatory: ${mandatory}"

	matched_names=$(prefix_matching_filter "${para_ref}" matching_filter) || rtn=$?

	if [[ ${rtn} -eq 0 ]]; then
		# matched(exact or prefix-), return the exact name
		para_ref="${matched_names}"
		return 0
	elif [[ ${mandatory} == true ]]; then
		# not matched but mandataory required
		case ${rtn} in
		1) # not matched
			if [[ ${lid} == "${OLID}" ]]; then
				pros_tag="${lid}${para_ref}"
				exit_with_msg 45
			else
				pros_tag="${ptitle}"
				pros_tag2="${lid}${para_ref}"
				exit_with_msg 43
			fi
			;;
		2) # multiple matched
			pros_tag="${ptitle}"
			pros_tag2="${lid}${para_ref}"
			pros_tag3="${matched_names// /|}"
			exit_with_msg 25
			;;
		*) ;;
		esac
	fi
	return 0
}

# validating a single para with given type and data
# used for Priors/PSets/UParas
function validate_para_arg() {
	local para=$1 e_para=$2 pf_type=$3 pf_data=$4 pf_mcg=$5

	# echo para: $para
	local val=${v_oparas[${e_para}]}

	pros_tag="${ptitle}"

	# [[ ${verbose} -ge 4 ]] && printf "    \e[2m%-8s - %-14s | %-6s | %10s | %-10s | %s\n\e[0m" \
	# "${para}" "${e_para}" "${pf_type}" "${pf_data}" "${val}" "${pf_mcg:--}" >&2
	case ${pf_type} in
	enum) # this branch must in front of "bool" branch in case EMAB
		# split enum string safely into array, handling escaped pipes
		local pf_data_escaped
		pf_data_escaped=$(echo "${pf_data}" | sed 's/\\|/__PIPE__/g')
		local IFS='|'
		read -ra enum_list <<<"${pf_data_escaped}"
		# Restore escaped pipes
		for i in "${!enum_list[@]}"; do
			enum_list[$i]=$(echo "${enum_list[$i]}" | sed 's/__PIPE__/|/g')
		done
		if [[ ${val} == true || ${val} == false ]]; then
			# an enum parameter want to use last value (-enum-para) may be missmatched as
			# booleans(enum mismatched as booleans EMAB)
			# remove the parameter from v_bools, re-assign with the last item of enum list
			unset "v_bools[${e_para}]"
			v_oparas[${e_para}]="${enum_list[-1]}"
			v_strings[${e_para}]="${enum_list[-1]}"
			return 0
		fi
		# try prefix-matching
		local pfm_names rtn=0
		declare -A pfm_names_map=()
		for name in "${enum_list[@]}"; do
			pfm_names_map["${name}"]=true
		done
		pfm_names=$(prefix_matching_filter "${val}" pfm_names_map) || rtn=$?
		case ${rtn} in
		0) # exactly or prefixly matched, assign the exact name back to parameter value
			v_oparas[${e_para}]="${pfm_names}"
			v_strings[${e_para}]="${pfm_names}"
			;;
		1) # not matched
			pros_tag2="${lid}${para}='${val}'"
			pros_tag3="${pf_data}"
			exit_with_msg 38
			;;
		2) # multiple matched
			pros_tag="enum value for"
			pros_tag2="${lid}${para}=${val}"
			pros_tag3="${pfm_names[*]//|/\/}"
			exit_with_msg 25
			;;
		*) ;;
		esac
		;;
	bool) # validate type
		if [[ ${val} != true && ${val} != false ]]; then
			pros_tag2="${para}='${val}'"
			pros_tag3="'true/false'"
			pros_tag4="'true' or 'false'"
			exit_with_msg 40
		fi
		;;
	string)
		if [[ ${val} == true || ${val} == false ]]; then
			pros_tag2="${para}='${val}'"
			pros_tag3="a string but got a bool"
			pros_tag4="a string"
			exit_with_msg 40
		fi
		;;
	resym)
		# if consist of resyms
		is_in_resyms "${val//[0-9]/}" || {
			pros_tag2="${para}='${val}'"
			pros_tag3="a RESYM or a RESYM-repetition but got '${val}'"
			pros_tag4="a special character or characters"
			exit_with_msg 40
		}
		# validate length of resym if specified in pf_data, e.g. "resym:3-_" means a parameter
		# with length of 3 and cannot contains '-' and '_' (sequence not matter)
		resym_len=${pf_data//[^[:digit:]]/}
		[[ -n ${resym_len} ]] || resym_len=1
		if [[ ${#val} -ne ${resym_len} ]]; then
			pros_tag2="${para}=${val}"
			pros_tag3="mismatch length, value length should be '${resym_len}' instead of '${#val}'"
			exit_with_msg 41
		fi
		# check exclude resyms
		exclude_resym="${pf_data//[0-9]/}"
		if [[ ${val} =~ [${exclude_resym}] ]]; then
			pros_tag2="${para}=${val}"
			pros_tag3="contains resym(s) not permitted '${exclude_resym}'"
			exit_with_msg 41
		fi
		;;
	*) # will not happen
		# pros_tag="${para}=${val}"
		# pros_tag2="${pf_type}"
		# pros_tag3="${ptitle} definition"
		# exit_with_msg 41
		;;
	esac
	return 0
}

# return all mcg names in the fillter
function get_all_mcg_names() {
	local lid=$1
	local -n pfilter=$2 mcg_groups_ref=$3
	local mem dummy mcg mcg_mem

	for mem in "${!pfilter[@]}"; do
		extract_def_entry "${lid}" "${mem}" pfilter dummy dummy mcg
		if [[ -n ${mcg} ]]; then
			# a para might belongs to multiple groups
			for mcg_mem in ${mcg//|/ }; do
				mcg_groups_ref["${mcg_mem}"]=true
			done
		fi
	done
}

# assert all mcg names satisfy MCG_TYPES
function validate_mcg_types() {
	local -n mcg_names_ref=$1
	local mem
	declare -a mcg_types=()

	# all available type in PFILTER
	for mem in "${MCG_TYPES[@]}"; do
		mcg_types+=("${mem#*:}")
	done

	# validate each parameter's mcg type
	for mem in "${mcg_names_ref[@]}"; do
		is_array_member "${mem:0:1}" mcg_types || {
			pros_tag="${mem}"
			pros_tag2="${mcg_types[*]}"
			exit_with_msg 53
		}
	done
}

# support both name-mutual-exclude and value-mutual-exclude
# check mcgs to ensure paras correctly configured
# for all Priors/PSets/User OParas
# support mcg-type:
#   - 'e':  exclusion: only one present
#           no fulfill
#           check: supplied count=[01]
#   - 'u':  uniqueness: vary values
#           no fulfill
#           check: values uniqueness on supplied members
#   - 'd/D' dependence: a capital one required by others
#           capital fulfill if defaut exist; other not
#           check:
#             - D-member:
#               - exclusion, no more than one D-member within a group
#               - mandatory if default exist
#               - fulfill if not supplied
#             - d-member: if supplied require D-member exist
#                         no defaulting for un-supplied
#   - 's':  sibling: present/absent together
#           any member supplied, fulfill others; no default will result an error unless supplied
#           check: all supplied(including fulfilled) or all un-supplied
# feature:
#    - validate type
#    - fulfill un-supplied paras for sibling group members
#    - validate mcg rules

function validate_para_mcg() {
	# too much extra checking for pfilter that has been done by filter validation
	local lid=$1
	local -n filter_ref=$2 vpe_paras=$3 vpe_bools=$4 vpe_strings=$5
	# echo "current filter:"
	# show_array filter_ref
	# echo "current paras for checking:"
	# show_array vpe_paras

	msg_bp 3 "  - check mutual-correlate groups"

	declare -A mc_groups=() sg_unsupplied=() sg_unsupplied_type=()
	local def_mcg member_mcg member_mcgs def_type Dg_member=""
	local def_data sgu
	declare -a mcg_type=() mcg_types=() mcg_list=()
	declare -a eg_members=() ug_members=() dg_members=() sg_members=()

	# get all mcg names
	get_all_mcg_names "${lid}" filter_ref mc_groups
	mcg_list=("${!mc_groups[@]}")
	msg_bp 4 "    mcg names: " "${mcg_list[*]}"

	# mcg name should honor MCG_TYPES
	validate_mcg_types mcg_list

	# process group by group
	for mcg in "${mcg_list[@]}"; do
		msg_bp 4 "    checking mcg: " "${mcg}"
		declare -a mcg_members=() supplied_members=()
		declare -A ug_values=()

		# find members in the same mcg
		for member in "${!filter_ref[@]}"; do
			member_mcg=${filter_ref[${member}]##*:}
			local IFS='|'
			read -ra member_mcgs <<<"${member_mcg}"
			if is_array_member "${mcg}" member_mcgs; then
				mcg_members+=("${member}")
			fi
		done

		# process by group type
		for member in "${mcg_members[@]}"; do
			extract_def_entry "${lid}" "${member}" filter_ref def_type def_data def_mcg
			case ${mcg:0:1} in
			e) # exclusion group lower members, count supplied, skip defaults
				if is_array_key "${member}" vpe_paras; then
					msg_bp 4 "      member " "'${member}' supplied"
					eg_members+=("${member}")
				fi
				;;
			s) # sibling group lower mumbers, count supplied, use defaults if not
				if is_array_key "${member}" vpe_paras; then
					msg_bp 4 "      member " "'${member}' supplied"
					sg_members+=("${member}")
				else
					#  not supplied
					msg_bp 4 "      member " "'${member}' un-supplied, use default"
					if [[ ${lid} == "${OLID}" ]]; then
						sg_unsupplied["${member}"]="${def_data}"
						sg_unsupplied_type["${member}"]="${def_type}"
					fi
				fi
				# default used, merge in to result values
				;;
			d) # dependence group lower mmbers, count supplied, skip un-supplied
				if is_array_key "${member}" vpe_paras; then
					msg_bp 4 "      member " "'${member}' supplied"
					dg_members+=("${member}")
				fi
				;;
			D) # capital dependence member
				if is_array_key "${member}" v_oparas; then
					msg_bp 4 "      member " "'${member}'"
					Dg_member="${member}"
				else
					# for user-paras, a default value for D-member means it should be loaded
					# with defualt; when no default exist and not supplied, skip
					# for Priors/PSets, no need to load defaults
					[[ ${lid} == "${OLID}" ]] && return
					if [[ -n ${def_data} ]]; then
						msg_bp 4 "      member " "'${member}' un-supplied, use default"
						vpe_paras["${member}"]="${def_data}"
						if [[ ${def_type} == "bool" ]]; then
							vpe_bools["${member}"]="${def_data}"
						else
							vpe_strings["${member}"]="${def_data}"
						fi
						Dg_member="${member}"
					fi
				fi
				;;
			u) # uniqueness group, collect count of values
				# values themself don't matter
				if is_array_key "${member}" vpe_paras; then
					# suplied, use parsed value
					msg_bp 4 "      member " "'${member}'"
					ug_values["${vpe_paras[${member}]}"]=true
				else
					# not supplied:
					# Priors/RSets, use CONFIGS as default; user-para skip
					if [[ ${lid} != "${OLID}" ]]; then
						# un-supplied priors/psets, use defaults in CONFIGS
						msg_bp 4 "      member " "'${member}' not supplied, use CONFIGS value for checking"
						if [[ ${lid} == "${PLID}" ]]; then
							ug_values["${CONFIGS[${PSETS[${member}]%%:*}]}"]=true
						elif [[ ${lid} == "${PRLID}" ]]; then
							ug_values["${CONFIGS[${PRIORS[${member}]%%:*}]}"]=true
						fi
					fi
				fi
				;;
			*) ;;
			esac
		done

		# exclude logic
		case ${mcg:0:1} in
		e) # exclusion: no more than one supplied
			msg_bp 4 "      - supplied members: " "${eg_members[*]}"
			if [[ ${#eg_members[@]} -gt 1 ]]; then
				pros_tag="${mcg}"
				pros_tag2="${eg_members[*]}"
				exit_with_msg 39
			fi
			;;
		u) # uniqueness group
			msg_bp 4 "      - collected member values: " "${ug_values[*]}"
			# value uniqueness: no duplicate values
			# if [[ ${#ug_values[@]} -ne $(printf '%s\n' "${ug_values[@]}" | sort -u | wc -l) ]]; then
			if [[ ${#ug_values[@]} -ne "${#mcg_members[@]}" ]]; then
				pros_tag="${mcg}"
				pros_tag2="${mcg_members[*]}"
				exit_with_msg 37
			fi
			;;
		s) # sibling: 0 or all
			if [[ ${#sg_members[@]} -ne 0 ]]; then
				# at least one member supplied
				if [[ ${#sg_members[@]} -ne "${#mcg_members[@]}" ]]; then
					# not all supplied, check unsupplied members
					for sgu in "${!sg_unsupplied[@]}"; do
						if [[ -n ${sg_unsupplied["${sgu}"]} ]]; then
							# default found, loaded as if supplied
							vpe_paras["${sgu}"]="${sg_unsupplied["${sgu}"]}"
							if [[ ${sg_unsupplied_type["${sgu}"]} == bool ]]; then
								vpe_bools["${sgu}"]="${sg_unsupplied[${sgu}]}"
							else
								vpe_strings["${sgu}"]="${sg_unsupplied[${sgu}]}"
							fi
						else
							# no default, raise an error
							pros_tag="${mcg}"
							pros_tag2="${!sg_unsupplied[*]}"
							pros_tag3="${mcg_members[*]}"
							exit_with_msg 54
						fi
					done
				fi
			fi
			;;
		d)
			# dependence: lowercase member depends on capical member
			# capical member can be supplied alone, but other cannot
			if [[ ${#dg_members[@]} -ne 0 ]]; then
				# d-member exist, check D-member it depends on
				if [[ -z ${Dg_member} ]]; then
					# no D-member
					pros_tag="${dg_members[*]}"
					pros_tag2="${mcg}"
					exit_with_msg 56
				fi
			fi
			;;
		D) ;; # no checking needed

		*) ;;
		esac

		msg_bp 4 "      - PASSED"
	done
}

# validate BP_OPARAS(Priors/PSets/User-OParas) with their definitions(PRIORS/PSETS/PFILTER)
function validate_paras_by_filter() {
	local lid=$1 mandatory=${2:-true}

	# local -n def=$2
	declare -A v_oparas=() v_strings=() v_bools=()

	local ptitle exact_para
	local para pf_type pf_data pf_mcg

	case ${lid} in
	"${OLID}") # for user parameters
		declare -n def=PFILTER
		ptitle="Parameter"
		;;
	"${PLID}") # for PSets
		declare -n def=PSETS
		ptitle="PSet"
		;;
	"${PRLID}") # for Priors
		declare -n def=PRIORS
		ptitle="Prior"
		;;
	*) ;;
	esac

	msg_bp 3 "  - validate names and args:"
	[[ ${verbose} -ge 4 ]] && printf "    \e[4;33m%-8s - %-14s | %-6s | %10s | %-10s | %s\n\e[0m" \
		"supplied" "matched" "type" "setting" "data" "mcg" >&2
	for para in "${!BP_OPARAS[@]}"; do
		# msg_bp 4 "    $para:"
		# validate name
		exact_para="${para}"
		validate_para_name exact_para def "${mandatory}"
		# load v_ arrays by types
		v_oparas["${exact_para}"]="${BP_OPARAS["${para}"]}"
		is_array_key "${para}" BP_STRINGS && v_strings["${exact_para}"]="${BP_STRINGS["${para}"]}"
		is_array_key "${para}" BP_BOOLS && v_bools["${exact_para}"]="${BP_BOOLS["${para}"]}"

		# check arg
		#   - if defined in def, do arg checking;
		#   - if not defined, let it be (for non-mandatory case)
		if is_array_key "${exact_para}" def; then
			extract_def_entry "${lid}" "${exact_para}" def pf_type pf_data pf_mcg
			validate_para_arg "${para}" "${exact_para}" "${pf_type}" "${pf_data}" "${pf_mcg}"
		else # not defined in def, let it be
			:
		fi
	done

	# show_array v_oparas "-OPARA-"
	# show_array v_bools "-BOOL-"
	# show_array v_strings "-STRING-"

	# check mcg conflict
	validate_para_mcg "${lid}" def v_oparas v_bools v_strings

	# load validated paras into result arrays
	reset_intermediate_arrays false
	for para in "${!v_oparas[@]}"; do
		BP_OPARAS["${para}"]="${v_oparas[${para}]}"
	done
	for para in "${!v_strings[@]}"; do
		BP_STRINGS["${para}"]="${v_strings[${para}]}"
	done
	for para in "${!v_bools[@]}"; do
		BP_BOOLS["${para}"]="${v_bools[${para}]}"
	done
}

# assign user parameters with defaults if not supplied
#   - for string/bool type, use data field
#   - for enum type, use first enum as default value
function assign_user_para_defaults() {
	local para=$1 pf_type=$2 pf_data=$3 pf_mcg=$4

	[[ ${verbose} -ge 4 ]] && printf "    \e[2;33m%-12s - %6s | %10s | %s\n\e[0m" \
		"${para}" "${pf_type}" "${pf_data:--}" "${pf_mcg:--}" >&2
	case "${pf_type}" in
	bool | string)
		if [[ -n ${pf_data} ]]; then
			# default value specified in PFILTER
			BP_OPARAS["${para}"]="${pf_data}"
			if [[ ${pf_type} == "bool" ]]; then
				BP_BOOLS["${para}"]="${pf_data}"
			else
				BP_STRINGS["${para}"]="${pf_data}"
			fi
		else # not supplied && no default value, parsing failed
			pros_tag="${para}"
			exit_with_msg 46
		fi
		# [[ ${verbose} -ge 3 ]] && printf "    \e[2m%-12s - %6s | %s\n\e[0m" "${para}" "${pf_type}" "${BP_OPARAS[${para}]:--}" >&2
		;;
	enum)
		# set with first enum as default value
		default_enum=${pf_data%%'|'*}
		BP_OPARAS["${para}"]="${default_enum}"
		# enum type is treated as string in BP_OPARAS(true|false should be set as Booleans)
		BP_STRINGS["${para}"]="${default_enum}"
		;;
	*) # this will not happen since integrity checking already done in validate_pfilter
		;;
	esac
	[[ ${verbose} -ge 3 ]] && printf "    \e[2m%-12s - %6s | %10s | %s\n\e[0m" "${para}" "${pf_type}" "${BP_OPARAS[${para}]:--}" "${pf_mcg}" >&2
	return 0
}

# validate user option parameters by PFILTER
#   validate PFILTER
#   validate para name(include prefixes)
#   validate para values
#   assign defaults for not supplied paras
# key paras:
#   mandatory(~amf): all parameters must be defined in PFILTER
#	PFILTER_ID: identify the PFILTER
function validate_user_paras() {
	msg_bp 2 "Validate user parameters"

	local para pf_type pf_data pf_mcg
	local mandatory no_pfilter=true
	# declare -a skip_defaults=()
	local skip_para

	mandatory="${CONFIGS[${PSETS["amf"]%%:*}]}"
	[[ "${CONFIGS[${PSETS["pf"]%%:*}]}" == "${NO_PFILTER}" ]] || no_pfilter=false

	msg_bp 4 "  PFILTER-ID: ${PFILTER_ID} | AMF: ${mandatory}"

	if [[ "${no_pfilter}" == true ]]; then
		[[ ${mandatory} == true ]] && exit_with_msg 44
		msg_bp 3 "  No PFILTER supplied, no validation for supplied parameters."
		return 0
	fi

	declare -A PFILTER
	msg_bp 3 "  Validate PFILTER"
	validate_pfilter "${CONFIGS[${PSETS["pf"]%%:*}]}"
	# msg_bp 4 "    PFILTER:"
	# [[ ${verbose} -ge 4 ]] && show_array PFILTER

	msg_bp 3 "  validate paras with PFILTER"
	validate_paras_by_filter "${OLID}" "${mandatory}"

	msg_bp 3 "  - assign default values if not supplied"
	[[ ${verbose} -ge 4 ]] && printf "    \e[4;33m%-12s - %6s | %10s | %s\n\e[0m" "para" "type" "data" "mcg" >&2
	for para in "${!PFILTER[@]}"; do
		# echo "para: $para"
		is_array_key "${para}" BP_OPARAS && continue
		extract_def_entry "${OLID}" "${para}" PFILTER pf_type pf_data pf_mcg
		# skip assignment for mcg members
		# echo "mcg name: #${pf_mcg}#"
		[[ -z ${pf_mcg} ]] || continue
		# echo assigning...
		assign_user_para_defaults "${para}" "${pf_type}" "${pf_data}" "${pf_mcg}"
	done
}

function create_variables() {
	local var
	msg_bp 2 "    Option parameters:"

	# bools
	for var in "${!BP_BOOLS[@]}"; do
		declare -g "${var}"="${BP_BOOLS["${var}"]}"
		msg_bp 2 "      ${var}"= "${BP_BOOLS["${var}"]}"
	done

	# strings
	for var in "${!BP_STRINGS[@]}"; do
		declare -g "${var}"="${BP_STRINGS[${var}]}"
		msg_bp 2 "      ${var}"= "${BP_STRINGS[${var}]}"
	done
}

# output parsing result as arrays with name references specified by user, e.g. if user specified
# "~oan=opara_array" for OAN from CML, then an array named "opara_array" will be created and
# assigned with all OParas, then user can use "${opara_array[@]}" to get all OParas in their
# script; if not specified, no array will be created for that type of paras.
#
# these arrays are for source mode, and will not be output in eval/capture mode since eval/capture
# mode will output variables in other formats; for example, in eval mode, variables will be output as
# variable assignment statements, and in capture mode, variables will be output as JSON string.
function output_para_arrays() {
	local opara_an key_max_len i
	# local spara_an bpara_an ppara_an i

	msg_bp 2 "  Output parameter arrays with name references specified in CONFIGS for PSets"

	# option parameters
	opara_an=${CONFIGS["${PSETS["oan"]%%:*}"]}
	max_array_key_len BP_OPARAS key_max_len 6
	if [[ ${opara_an} != "${CONSTS["OAN"]}" ]]; then
		msg_bp 2 "  - Option parameters in '${opara_an}()'"
		declare -gA "${opara_an}=()"
		declare -n arr_ref="${opara_an}"
		for i in "${!BP_OPARAS[@]}"; do
			arr_ref["${i}"]="${BP_OPARAS[${i}]}"
			# msg_bp 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${BP_OPARAS[${i}]}")"
			msg_bp 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${arr_ref[${i}]}")"
		done
	fi

	# bool parameters
	bpara_an=${CONFIGS["${PSETS["ban"]%%:*}"]}
	max_array_key_len BP_Bools key_max_len 6
	if [[ ${bpara_an} != "${CONSTS["BAN"]}" ]]; then
		msg_bp 2 "  - Boolean parameters in '${bpara_an}()'"
		declare -gA "${bpara_an}=()"
		declare -n arr_ref="${bpara_an}"
		for i in "${!BP_BOOLS[@]}"; do
			arr_ref["${i}"]="${BP_BOOLS[${i}]}"
			# msg_bp 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${BP_BOOLS[${i}]}")"
			msg_bp 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${arr_ref[${i}]}")"
		done
	fi

	# string parameters
	spara_an=${CONFIGS["${PSETS["san"]%%:*}"]}
	max_array_key_len BP_Strings key_max_len 6
	if [[ ${spara_an} != "${CONSTS["SAN"]}" ]]; then
		msg_bp 2 "  - String parameters in '${spara_an}()'"
		declare -gA "${spara_an}=()"
		declare -n arr_ref="${spara_an}"
		for i in "${!BP_STRINGS[@]}"; do
			arr_ref["${i}"]="${BP_STRINGS[${i}]}"
			# msg_bp 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${BP_STRINGS[${i}]}")"
			msg_bp 2 "  $(printf "%${key_max_len}s | %s\n" "${i}" "${arr_ref[${i}]}")"
		done
	fi

	# position parameters
	# PAN is a special case since it is used for identifying the array name for PParas, and it
	# is not necessary to create an array for PParas if user do not specify a name for it; so
	# only when PAN is specified with a different name, the array for PParas will be created.
	ppara_an=${CONFIGS["${PSETS["pan"]%%:*}"]}
	if [[ ${ppara_an} != "${CONSTS["PAN"]}" ]]; then
		msg_bp 2 "  - Positional parameters in '${ppara_an}()'"
		declare -gA "${ppara_an}=()"
		declare -n arr_ref="${ppara_an}"
		if [[ ${#BP_PPARAS[@]} -ne 0 ]]; then
			for i in "${!BP_PPARAS[@]}"; do
				arr_ref["${i}"]="${BP_PPARAS[${i}]}"
				msg_bp 2 "      ${arr_ref[${i}]}"
			done
		fi
	fi
}

# output parsing result as variable assignment statements, for eval mode
function output_eval() {
	# output vars
	local index
	for index in "${!BP_OPARAS[@]}"; do
		echo "${index}=$(printf %q "${BP_OPARAS[${index}]}")"
	done
	# output optional parameters as vars
	# variable name prefix
	ppvn_prefix="${CONFIGS[${PSETS["pan"]%%:*}]}"
	for index in "${!BP_PPARAS[@]}"; do
		echo "${ppvn_prefix,,}_${index}=$(printf %q "${BP_PPARAS[${index}]}")"
	done
}

# output parsing result as JSON, for capture mode
function output_json() {
	# output $BP_OPARAS in JSON using a single jq -n call
	command -v jq >/dev/null 2>&1 || exit_with_msg 47

	local para val idx=0
	local -a jq_args=()
	local expr='{}'

	# helper: valid number check (no leading zeros except '0')
	is_number() {
		[[ $1 =~ ^-?(0|[1-9][0-9]*)(\.[0-9]+)?$ ]]
	}

	for para in "${!BP_OPARAS[@]}"; do
		val="${BP_OPARAS[${para}]}"
		idx=$((idx + 1))
		jq_args+=(--arg "k${idx}" "${para}")
		if [[ "${val}" == "true" || "${val}" == "false" ]]; then
			# boolean literal
			jq_args+=(--argjson "v${idx}" "${val}")
		elif is_number "${val}"; then
			# numeric literal (integers or decimals without leading zeros)
			jq_args+=(--argjson "v${idx}" "${val}")
		else
			# force string
			jq_args+=(--arg "v${idx}" "${val}")
		fi
		expr+=" + {(\$k${idx}): \$v${idx}}"
	done

	# Emit positional parameters as a JSON array under the key 'PParas'
	if [[ ${#BP_PPARAS[@]} -gt 0 ]]; then
		local pparas_json
		pparas_json=$(printf '%s\n' "${BP_PPARAS[@]}" | jq -R -s -c 'split("\n")[:-1]')
		idx=$((idx + 1))
		jq_args+=(--arg "k${idx}" "${CONFIGS[${PSETS["pan"]%%:*}],,}")
		jq_args+=(--argjson "v${idx}" "${pparas_json}")
		expr+=" + {(\$k${idx}): \$v${idx}}"
	fi

	jq -n "${jq_args[@]}" "${expr}"
}

function direct_pset_commands() {
	# direct commands for some special PSets, which will not be output as user parameters but
	# executed directly in bosparse, e.g. show version or print a message

	# show bosparse tag
	if [[ "${CONFIGS[${PSETS["Banner"]%%:*}]}" == true ]]; then
		# show banner
		echo -e "${CONSTS["PBP"]} with love"
	elif [[ "${CONFIGS[${PSETS["Version"]%%:*}]}" == true ]]; then
		# show version
		echo "${CONSTS["BOSPARSE_VERSION"]}"
	elif [[ "${CONFIGS[${PSETS["Rsymbols"]%%:*}]}" == true ]]; then
		# show resym
		echo "Available resyms: ${RESYMS[*]}"
	elif [[ "${CONFIGS[${PSETS["Config"]%%:*}]}" == true ]]; then
		# show_configs
		show_configs
	else
		return 0
	fi
	exit 0
}

# main function ---------------------------------------------------------------
function bosparse() {

	# trap on_exit_bp EXIT

	local_script_path="$(realpath "${BASH_SOURCE[0]}")"
	local_script_dir="${local_script_path%\/*}"
	local_script_name="${local_script_path##*\/}"

	declare -A CONFIGS CONSTS PSETS
	declare -A PRIORS LIDS EXCEPTIONS EXIT_MSG MCG_TYPES
	declare -a RESYMS PFILTER_ENTRY_TYPES
	# declare -A PSET_FILTER=()

	declare -a op_zone=() pp_zone=()
	declare -a strings=() bools=() ligas=()

	# local variables
	local verbose
	local __QUIET __STANDARD __EXTRA __DEBUG __TRACE

	definitions \
		CONFIGS \
		CONSTS \
		PSETS \
		PRIORS \
		LIDS \
		RESYMS \
		EXCEPTIONS \
		EXIT_MSG \
		PFILTER_ENTRY_TYPES \
		MCG_TYPES

	declare -n PRLID='LIDS["prior"]'
	declare -n PLID='LIDS["plid"]'
	declare -n OLID='LIDS["olid"]'
	declare -n RUN_MODE="CONFIGS[${PSETS["run"]%%:*}]"
	declare -n ZSEP="CONFIGS[${PRIORS["zs"]%%:*}]"
	declare -n OSEP="CONFIGS[${PRIORS["os"]%%:*}]"
	declare -n TAG_TRUE="CONFIGS[${PRIORS["tt"]%%:*}]"
	declare -n TAG_FALSE="CONFIGS[${PRIORS["tf"]%%:*}]"
	declare -n TAG_DEFAULT="CONFIGS[${PRIORS[td]%%:*}]"
	declare -n NO_PFILTER='CONSTS["NO_PFILTER"]'
	declare -n PFILTER_ID='CONSTS["PFILTER_ID"]'

	# arrays for parsing result
	#   - BP_OPARAS is the main result array for all types of OParas
	#   - BP_STRINGS/BP_BOOLS are for storing string/bool type OParas separately
	#   - BP PParas entries are all position parameters
	# BP_PParas defined as global array since it is always needed for source mode, while others
	# defined as local arrays to reduce global variable usage and avoid potential conflicts with
	# user variables; for eval/capture mode, these arrays will not be used directly, so it does
	# not matter if they are global or local.

	declare -A "${CONSTS["OAN"]}"
	declare -A "${CONSTS["SAN"]}"
	declare -A "${CONSTS["BAN"]}"
	declare -ga "${CONSTS["PAN"]}"

	declare -n "BP_OPARAS=${CONSTS["OAN"]}"
	declare -n "BP_STRINGS=${CONSTS["SAN"]}"
	declare -n "BP_BOOLS=${CONSTS["BAN"]}"
	declare -n "BP_PPARAS=${CONSTS["PAN"]}"

	# echo ---------------------
	# echo $* >&2

	# super verbose, for debugging
	local super_verbose
	if [[ $* =~ ~~~~[a-zA-Z0-9_-]+ ]]; then
		super_verbose="${BASH_REMATCH[0]##*\~}"
		echo "super_verbose: ${super_verbose}"
	fi
	# echo verbose: ${verbose:-} >&2
	update_verbose "${super_verbose:-}"

	msg_bp 3 "Command line: " "$*"
	# echo "Command line: $*" >&2
	msg_bp -2 "verbose: " "${verbose}"

	# treat empty "$@"
	[[ $# -eq 0 || $* == '--' || $* == "${ZSEP}" ]] && exit_with_msg 2

	reset_intermediate_arrays

	# disassemble command line parameters
	msg_bp 2 "Extract Zones"
	extract_zones op_zone pp_zone "$@"

	# show_array op_zone "|"
	# show_array pp_zone "|"

	msg_bp 3 "Extract Priors"
	extract_oparas "${PRLID}" strings bools ligas op_zone || true

	msg_bp 2 "Parse Priors"
	parse_oparas "${PRLID}" strings bools ligas

	if [[ ${#BP_OPARAS[@]} -ne 0 ]]; then
		msg_bp 3 "Validate Priors"
		validate_paras_by_filter "${PRLID}" true

		# show_array CONFIGS "CF"

		msg_bp 3 "Apply Priors"
		apply_setup "Priors" PRIORS
		update_verbose
	fi
	reset_intermediate_arrays

	if [[ ${CONFIGS[${PRIORS["config"]%%:*}]} == true ]]; then
		# if config is true, show configs after parsing Priors
		show_configs
		# set config to false after showing configs, to avoid showing configs again after parsing PSets
		CONFIGS["${PRIORS["config"]%%:*}"]=false
	else
		[[ ${verbose} -ge 3 ]] && show_configs
	fi

	# re-extract zones for PSets and user OParas, in case some prior settings changed
	msg_bp 2 "Extract Zones Again"
	extract_zones op_zone pp_zone "$@"

	msg_bp 4 "op zone:" "${op_zone[*]}"
	msg_bp 4 "pp zone:" "${pp_zone[*]}"

	# Psets
	msg_bp 3 "Extract PSets"
	extract_oparas "${PLID}" strings bools ligas op_zone || true

	msg_bp 2 "Parse PSets"
	parse_oparas "${PLID}" strings bools ligas

	if [[ ${#BP_OPARAS[@]} -ne 0 ]]; then

		msg_bp 3 "Validate PSets"
		validate_paras_by_filter "${PLID}" true

		msg_bp 3 "Apply PSets"
		apply_setup "PSets" PSETS
		update_verbose

		# directives for some special PSets, which will not be output as user parameters but
		# executed directly in bosparse, e.g. show version or print banner
		direct_pset_commands
	fi
	reset_intermediate_arrays false

	if [[ ${CONFIGS[${PSETS["config"]%%:*}]} == true ]]; then
		# if config is true, show configs after parsing PSets
		show_configs
	else
		[[ ${verbose} -ge 3 ]] && show_configs
	fi

	# parsing user parameter parsing
	msg_bp 2 "Extract user-oparas"
	extract_oparas "${OLID}" strings bools ligas op_zone || true

	msg_bp 2 "Parse user-oparas"
	parse_oparas "${OLID}" strings bools ligas || true
	validate_user_paras

	msg_bp 2 "Parse user-pparas"
	parse_pparas "${pp_zone[@]}"

	# prepare parsing result on user requirement
	msg_bp 2 "Output parsing result"

	# the user set ~run/mode (PSet) will be respect; Otherwise autodetect
	if [[ ${RUN_MODE} == "auto" ]]; then # auto is the default value
		# echo "simple assert: ${BASH_SOURCE[0]} | "$0" "
		# echo "full assert:   $(basename "$(realpath "${BASH_SOURCE[0]}")") | $(basename "$0") "
		#
		# full assertion is necessary since in some edge cases, e.g. when bosparse is called in
		# a script which is sourced by another script, simple assert will fail to detect source
		# mode; in this case, full assert can correctly detect source mode by comparing the real
		# path of BASH_SOURCE[0] with $0, since when sourced, BASH_SOURCE[0] is the path of the
		# sourced script, while $0 is the path of the top-level script.

		# autodetect
		if [[ ${local_script_name} != $(basename "$0") ]]; then
			msg_bp 3 "  Sourced, output option parameters as variables."
			RUN_MODE="source"
		else
			if [[ ${CONFIGS[${PSETS["json"]%%:*}]} == true ]]; then
				msg_bp 3 "Not sourced, use 'capture' mode as 'json' specified."
				RUN_MODE="capture"
			else
				msg_bp 3 "Not sourced, use 'eval' mode as default"
				RUN_MODE="eval"
			fi
		fi
	fi

	case ${RUN_MODE} in
	source)
		msg_bp 3 "  Output as variables."
		create_variables
		output_para_arrays
		;;
	eval)
		msg_bp 3 "  Output as eval statements."
		output_eval
		;;
	capture)
		msg_bp 3 "  Output as JSON."
		output_json
		;;
	*) ;;
	esac
	parsing_result="Mission complete."
	msg_bp 3 "${parsing_result}"
}

__BP_READY=true # identifying bosparse used

# echo "source assert: $(basename "$(realpath "${BASH_SOURCE[0]}")") | $(basename "$0") "
if [[ $(basename "$(realpath "${BASH_SOURCE[0]}")") == $(basename "$0") ]]; then
	# not source mode
	bosparse "$@"
fi
